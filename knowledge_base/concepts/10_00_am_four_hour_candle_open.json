{
  "card_id": "10_00_am_four_hour_candle_open",
  "type": "merged_concept",
  "canonical_term": "10:00 AM Four-Hour Candle Open",
  "aliases": [
    "10 am 4h open",
    "10 AM 4H Open",
    "10:00 EST 4-Hour Candle Open",
    "10:00 est 4-hour candle open"
  ],
  "school": "ICT",
  "definition": "The 10:00 AM EST opening price of a new four-hour candle on index futures, used as a reference point to anticipate the Power of Three (open-high-low-close) delivery of that 4H candle and to time retracement or continuation entries within it.",
  "identification_rules": [
    "Mark the price at 10:00 AM EST as the open of a new 4-hour candle on index futures (timing differs for Forex).",
    "If bias is bullish, anticipate an open-low-high-close: price drops below the 10:00 open early to manipulate, then expands higher into the close.",
    "If bias is bearish, anticipate an open-high-low-close: price runs above the 10:00 open early, then distributes lower.",
    "Confirm the 4H delivery by observing the lower-time-frame reaction (sweep + change in state of delivery) immediately after 10:00.",
    "Expect the next 4H candle open at 2:00 PM EST to deliver retracement or continuation relative to the 10:00 candle's structure."
  ],
  "trading_implication": "The 10:00 AM 4H open is used to frame the Power of Three on the 4-hour timeframe. Traders use it to anticipate where the manipulation wick of the 4H candle will form versus its expansion body, timing entries on the lower time frame at or shortly after 10:00 EST. It pairs with the 2:00 PM 4H open for retracement timing and is combined with midnight open, 8:30, and 9:30 levels to confirm bias before executing.",
  "common_mistakes": [
    "Applying the 10:00 AM open universally without adjusting for asset class (Forex 4H candles open at different times).",
    "Trading the 10:00 candle without an established higher time frame bias, leading to misreading manipulation as the real move.",
    "Expecting expansion immediately at 10:00 instead of allowing the manipulation leg (low for bullish, high for bearish) to form first."
  ],
