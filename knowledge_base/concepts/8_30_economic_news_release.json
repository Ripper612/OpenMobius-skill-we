{
  "card_id": "8_30_economic_news_release",
  "type": "merged_concept",
  "canonical_term": "8:30 Economic News Release",
  "aliases": [
    "8:30 news",
    "8:30 News",
    "8:30 open",
    "8:30 Open",
    "news embargo lift",
    "News Embargo Lift"
  ],
  "school": "ICT",
  "definition": "The 08:30 EST time level when the news embargo lifts and high-impact economic data is released. Used as a support/resistance and premium/discount reference, and as a Judas swing or order block formation time where an opposing run is expected before the true directional move.",
  "identification_rules": [
    "Mark a horizontal level at the 08:30 EST price on the chart as a reference for support/resistance and premium/discount.",
    "If price is bullish and trading above 08:30, treat the level as a deep premium; if bearish and trading below, treat it as a deep discount.",
    "Identify an opposing run at 08:30 against the anticipated daily bias (e.g., a run lower when bullish) followed by a closure back through the opposing candle series to validate an order block.",
    "After validation, the swing low/high formed by the 08:30 opposing run should not be taken out if the anticipated directional move is to occur.",
    "Pair the 08:30 level with the midnight open and 09:30 open as stacked support/resistance levels confirming the order block."
  ],
  "trading_implication": "The 08:30 release is treated as a manipulation/Judas swing window inside the daily Power of 3. Traders anticipate an opposing run at 08:30 that sweeps short-term liquidity and forms an order block paired with midnight open, then look for distribution into the true direction at 09:30 or 10:00. The 08:30 level then functions as support/resistance on retracements, and premium/discount positioning relative to it informs whether to look for longs or shorts.",
  "common_mistakes": [
    "Treating the 08:30 move as the true directional move rather than as a Judas/opposing run before distribution.",
    "Ignoring premium/discount positioning relative to 08:30 and midnight open when seeking entries.",
    "Failing to wait for a closure back through the opposing candle series to validate the 08:30 order block."
  ],
