{
  "card_id": "asia_session",
  "type": "merged_concept",
  "canonical_term": "Asia Session",
  "aliases": [
    "asia",
    "Asia",
    "Asia Range",
    "Asian Session",
    "asian session"
  ],
  "school": "ICT",
  "definition": "The overnight trading session (approximately 20:00–00:00 EST) characterized by a consolidation range that marks the accumulation phase in the AMD cycle, with its high and low serving as key liquidity targets for London and New York.",
  "identification_rules": [
    "Set the chart time zone to New York (EST) to avoid daylight-savings misalignment.",
    "Define the Asia session as 20:00–00:00 EST.",
    "Identify the highest high and lowest low within this period to form the Asia range.",
    "Confirm the price action is consolidative, moving sideways without aggressive directional displacement.",
    "Mark the Asia high and low as liquidity levels that London and New York will target.",
    "Check if the Asia session has already swept the previous day's high or low; if so, it may consume the liquidity target for the New York session."
  ],
  "trading_implication": "Asia Session functions as the accumulation phase of the AMD (Accumulation-Manipulation-Distribution) cycle. Its high and low become liquidity pools: London manipulates by sweeping one side and displacing back into the range, while New York typically distributes in the opposite direction. If the Asia session has already swept a prior day's high or low, the New York entry targeting that level is skipped. Traders may project the London manipulation leg using standard deviation to set New York distribution targets.",
  "common_mistakes": [
    "Taking a New York session entry targeting previous day high/low when Asia has already swept that level.",
    "Failing to set chart time zone to New York, causing misalignment of the Asia session window.",
    "Confusing Forex and indices session timings; ensure the Asia window is correctly applied.",
    "Expecting a directional move during Asia; it is primarily a consolidation/accumulation phase.",
    "Entering a trade before waiting for aggressive displacement back into the Asia range to confirm the manipulation leg."
  ],
