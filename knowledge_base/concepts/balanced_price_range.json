{
  "card_id": "balanced_price_range",
  "type": "merged_concept",
  "canonical_term": "Balanced Price Range",
  "aliases": [
    "balanced price range (bpr)",
    "Balanced Price Range (BPR)",
    "box",
    "bpr",
    "BPR",
    "平衡价格区间"
  ],
  "school": "ICT",
  "definition": "A precision entry zone formed by the overlapping area of a bullish and a bearish fair value gap at the same price level, created after an aggressive liquidity sweep and sharp return. It serves as a strong support/resistance area for high-probability entries, often associated with higher timeframe points of interest.",
  "identification_rules": [
    "Identify a higher timeframe point of interest (previous high/low, fair value gap, order block) as context.",
    "Wait for an aggressive sweep of a short-term high (for shorts) or low (for longs) beyond the current range.",
    "Confirm an aggressive, sharp return move back inside the range, generating a bullish and a bearish fair value gap that overlap at the same price level.",
    "Mark the overlapping area of the two opposing fair value gaps as the Balanced Price Range.",
    "The BPR can be bullish (bearish FVG then bullish FVG) or bearish (bullish FVG then bearish FVG).",
    "On lower timeframes (e.g., 1m, 5s, 15s), BPR is more easily identified; on higher timeframes, it may appear as a hammer or shooting star wick.",
    "For bullish BPR, the zone should be in the discount zone (below equilibrium); for bearish BPR, in the premium zone.",
    "BPR typically appears in a consolidation → aggressive breakout → aggressive retest cycle."
  ],
  "trading_implication": "BPR provides a high-probability entry zone after a liquidity sweep, enabling entries without a market structure shift. Traders wait for price to retrace into the overlapping area and react. Entry can be taken on reversal signals (reversal candle, candle 2 closure, change in delivery) on lower timeframes, with stops beyond the swept high/low, targeting liquidity levels for a minimum 2R return. If price aggressively penetrates BPR without reaction, shift to the next PD array.",
  "common_mistakes": [
    "Confusing BPR with a single FVG or a simple consolidation range; BPR requires two opposing FVGs overlapping.",
    "Failing to require an aggressive sweep and return; weak or gradual moves do not form valid BPRs.",
    "Overlooking the need for a higher timeframe point of interest as context.",
    "Entering before the opposing fair value gaps fully form and overlap.",
    "Trading BPR in the wrong premium/discount zone (e.g., bullish BPR in premium zone).",
    "Ignoring failure to displace signals within BPR, continuing with bias instead of reversing.",
    "Not verifying BPR across multiple timeframes, leading to unreliable signals.",
    "Holding onto BPR as a target when price shows no reaction, rather than adapting to the next PD array."
  ],
