{
  "card_id": "box_setup",
  "type": "merged_concept",
  "canonical_term": "Box Setup",
  "aliases": [
    "Accumulation Box",
    "Box Entry",
    "Box Entry Model",
    "Box Range Setup",
    "Consolidation Box",
    "Previous Body Setup",
    "Range Box",
    "Range Setup",
    "价格框架设置",
    "偏离-回测框架",
    "盒形设置"
  ],
  "school": "ICT",
  "definition": "标记盘整区间K线实体高低点形成的交易框架，基于积累-操纵-派发周期。识别价格激进突破区间后的回测，在回测至盘整边界、FVG、OB或折价区时寻找入场点，止损设于区间另一侧，目标指向对立方向流动性或标准差投影。",
  "identification_rules": [
    "用K线实体（不含影线）的最高点和最低点标记盘整区间的上下边界，确保为多根K线形成的明确区间",
    "识别激进突破：价格快速穿出盘整区间，通常伴随FVG形成，突破需有明显力度和速度",
    "识别激进回测：价格随后快速回到盘整区间附近，再次伴随FVG或BPR形成",
    "在回测处寻找入场：价格重新测试盘整边界、FVG、OB或折价区时作为多头或空头入场点",
    "若难以识别明确区间，可在Displacement发生后向左看，标记被突破的旧高点或低点作为Box参考水平",
    "可选：标记前一根K线的收盘价或实体低点作为Box参考水平，等待价格回测该水平",
    "可选：将操纵腿投影回原区间，确定潜在目标位（通常对应前期高点、FVG或-2至-2.5标准差）",
    "使用高时间框架（1小时、4小时、日线）确定交易偏向，在低时间框架（15分钟、5分钟、30秒）执行具体入场",
    "确认价格处于折价区（做多）或溢价区（做空），避免在不利区域入场"
  ],
  "trading_implication": "Box Setup用于在AMD周期中定位积累阶段并捕捉激进突破后的回测入场机会。高时间框架确认偏向和目标，低时间框架等待价格回测盘整边界或相关PD阵列（FVG、OB）后入场，止损设于区间另一侧或激进运动极值，目标指向对立方向流动性、前期高低点或标准差投影，通常可获得2R以上风险回报比。也可在无低时间框架流动性扫除时灵活使用。",
  "common_mistakes": [
    "用K线影线而非实体标记盘整框，导致边界不准确",
    "试图在盘整区间内交易，而非等待激进突破和回测完成",
    "过度关注盘整区间本身，忽视激进突破和回测的动作质量",
    "突破或回测动作不够激进，无法形成有效的wick结构，降低设置有效性",
    "未等待CSD、MSS或Order Block确认就仓促入场",
    "未等待收盘确认就入场，导致被假突破扫出",
    "忽视价格是否处于折价区或溢价区，在不利位置入场",
    "在没有明确止损点或结构转变参考的情况下使用Box Setup",
    "忽视AMD模式中的操纵阶段，误认为操纵后立即分布而错过真正入场机会",
    "在高时间框架执行Box Setup而非低时间框架，导致风险过大",
    "忽视FVG和BPR的存在，未能正确识别回测的精确位置",
    "未能结合标准差投影或其他目标工具，导致目标位设置不当",
    "不区分不同交易时段的流动性差异，导致目标已被扫除后仍入场",
    "混淆Box Setup与Inducement——Box Setup需要激进的出入，Inducement是虚假突破后的反向运行",
    "混淆Box的最高/最低实体与高/低影线，导致目标计算错误",
    "在买方曲线上做空、在卖方曲线上做多，导致价格穿过预期反转点继续运行"
  ],
