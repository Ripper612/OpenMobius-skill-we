{
  "card_id": "break_of_structure",
  "type": "merged_concept",
  "canonical_term": "Break of Structure",
  "aliases": [
    "bos",
    "BOS",
    "break structure",
    "market structure break",
    "Market Structure Break",
    "shift in structure",
    "Shift in Structure",
    "structure break",
    "Structure Break"
  ],
  "school": "ICT",
  "definition": "A price move that aggressively closes beyond a previous swing high or low with displacement candles, confirming a structural shift from bullish to bearish or vice versa. In an uptrend, a close below a prior swing low; in a downtrend, a close above a prior swing high.",
  "identification_rules": [
    "For a bearish break, identify a sweep of a swing high, then a close below a prior swing low with full-bodied displacement candles.",
    "For a bullish break, identify a sweep of a swing low, then a close above a prior swing high with full-bodied displacement candles.",
    "Displacement must consist of large candle bodies with small wicks, creating fair value gaps, not slow grinding moves.",
    "A break of structure is only confirmed after the sweep and when price closes beyond the structural level; wicking through alone is insufficient.",
    "In an uptrend (higher highs + higher lows), wait for price to close below the most recent confirmed swing low.",
    "In a downtrend (lower highs + lower lows), wait for price to close above the most recent confirmed swing high.",
    "After the break, observe if a reverse swing point (e.g., lower high after bearish break) forms to confirm trend change.",
    "The swing point used for the break should be the one that pushed price to a new high/low (i.e., the low before the new high, or the high before the new low).",
    "On 15-minute or 5-minute charts, draw BOS lines horizontally connecting swing highs/lows.",
    "After BOS, look for Fair Value Gaps (FVG) within the displacement zone as entry areas."
  ],
  "trading_implication": "A break of structure signals a trend reversal and validates order blocks for entry. Traders adopt a directional bias aligned with the break, entering on retracements to valid order blocks or FVG discount zones on lower timeframes (5min/1min). Stop loss beyond the BOS extreme. Target prior liquidity levels. Without a break, order blocks are not valid. Combine with higher timeframe trend: if lower timeframe BOS opposes higher timeframe, it may be a retracement.",
  "common_mistakes": [
    "Treating a liquidity grab (wick through with no close beyond) as a valid break of structure.",
    "Using order blocks that did not form after a structural break, which lack validity.",
    "Accepting small-bodied candles without displacement as confirmation, leading to false signals.",
    "Entering before BOS confirmation, relying only on liquidity sweep.",
    "Looking for BOS on 1-minute chart, which is prone to false breaks; use 5-minute or 3-minute instead.",
    "Not waiting for a reverse swing point (e.g., lower high) after BOS before entering.",
    "Ignoring higher timeframe trend and trading against it on lower timeframe BOS."
  ],
