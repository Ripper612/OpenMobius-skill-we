{
  "card_id": "candle_2_3_closure",
  "type": "merged_concept",
  "canonical_term": "Candle 2/3 Closure",
  "aliases": [
    "C3",
    "C3 closure",
    "Candle 2 Closure",
    "candle 3 closure",
    "Candle 3 Closure"
  ],
  "school": "ICT",
  "definition": "A concept used to assess price reaction at relevant swing points by observing the close of the 2nd or 3rd candle. The wick or equilibrium (50% level) of that candle is compared to the swing point to confirm reversal or breakout validity. In a fractal model, Candle 3 (C3) is the close of the third candle on a higher timeframe, used with C4 continuation for trade setups.",
  "identification_rules": [
    "Price trades into a relevant swing high or low, then count the forming candle sequence.",
    "Observe the close of the 2nd or 3rd candle.",
    "Compare the candle's wick or equilibrium (50% midpoint) to the swing point level.",
    "If the close or wick respects the swing level, the reaction is valid; a break indicates manipulation or breakout.",
    "In the fractal model, enable C3 in indicator settings to automatically mark the close of the third candle on the higher timeframe.",
    "C3 is typically used with C4 continuation to form a complete trade signal.",
    "C3 label appears as a rectangle on the chart at the close price range of the higher timeframe candle.",
    "C3 display can be independently enabled or disabled via the indicator's Fractal parameter."
  ],
  "trading_implication": "Candle 2/3 Closure helps determine the validity of price reaction at swing points, distinguishing real reversals (manipulation) from breakouts. For C3 in the fractal model, observe if C4 continuation occurs to confirm the setup. If the setup fails within C4, it is marked as failed; otherwise, continue tracking. Combine with C2 and C4 for multi-timeframe high-probability entries.",
  "common_mistakes": [
    "Applying the rule at irrelevant swing points instead of relevant ones.",
    "Focusing only on the close and ignoring the wick or equilibrium level.",
    "Using the rule without considering valid separation (swing points too close).",
    "Using C3 alone without C4 continuation confirmation.",
    "Confusing C3 state colors: gray means setup still valid, red means failed within first candle, orange means failed after second candle."
  ],
