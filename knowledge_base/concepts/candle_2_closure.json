{
  "card_id": "candle_2_closure",
  "type": "merged_concept",
  "canonical_term": "Candle 2 Closure",
  "aliases": [
    "C2",
    "C2 Closure",
    "C2C",
    "Candle to Closure",
    "Reversal Closure",
    "Second Candle Closure",
    "第二根K线收盘"
  ],
  "school": "ICT",
  "definition": "价格在当前K线内扫过前一根K线的高点或低点（扫出流动性）后，收盘回到前一根K线范围内或反向侧，预示价格即将反向运动的K线形态。看涨场景：扫低后收盘回到前低上方；看跌场景：扫高后收盘回到前高下方。",
  "identification_rules": [
    "价格在当前K线内扫过前一根K线的极值（高点或低点）",
    "当前K线收盘价回到前一根K线的范围内，或收盘于扫出极值的反向侧",
    "看涨场景：扫过前一根K线低点后，收盘回到该低点上方或前一根K线范围内",
    "看跌场景：扫过前一根K线高点后，收盘回到该高点下方或前一根K线范围内",
    "该形态应出现在高时间框架关键价格水平（如FVG、摆动高低点、订单块）附近，以提高信号有效性"
  ],
  "trading_implication": "Reversal Closure是判断价格反转意图的高概率信号。识别后可预期第3根K线（Candle 3/Expansion Candle）沿反转方向扩展，第4根K线进一步确认趋势。可与equilibrium（0.5斐波那契水平）配合，在expansion candle的上半部分（看涨）或下半部分（看跌）寻找wick形成位置作为入场依据。常与订单块、公允价值缺口等高时间框架关键水平结合使用确认反转点。",
  "common_mistakes": [
    "混淆Reversal Closure与Continuation Closure：前者收盘回到前一根K线内部预示反转，后者收盘突破前一根K线范围预示趋势延续",
    "在Candle 2 Closure未形成时过早交易Candle 3，应等待明确的reversal closure信号",
    "在没有高时间框架关键水平支撑的情况下，对每个扫过并回闭的形态都视为Reversal Closure，降低信号有效性",
    "忽视与equilibrium的配合使用，导致expansion candle的目标位置判断不准"
  ],
