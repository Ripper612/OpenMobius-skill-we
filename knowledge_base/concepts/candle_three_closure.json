{
  "card_id": "candle_three_closure",
  "type": "merged_concept",
  "canonical_term": "Candle Three Closure",
  "aliases": [
    "C3",
    "C3 Closure",
    "三号收盘"
  ],
  "school": "ICT",
  "definition": "当前两根K线未形成理想的二号收盘（Candle Two Closure）时，第三根K线不突破第二根K线的高低点，但收盘于第二根K线主体上方（看涨）或下方（看跌），作为替代确认信号，预期第四根K线延续该方向，通常需结合受保护摆动点与高时间框架关键水平使用。",
  "identification_rules": [
    "确认前两根K线未形成二号收盘（第二根K线未扫出第一根K线的高/低并收回）",
    "第三根K线不突破第二根K线的高点或低点",
    "第三根K线收盘于第二根K线主体上方（看涨情景）或下方（看跌情景）",
    "第三根K线收盘应形成新的受保护摆动点（Protected Swing）",
    "必须存在高时间框架关键水平（如FVG、摆动点、前一日高/低点、均衡点）作为背景",
    "第四根K线通常会沿第三根K线指示的方向延续"
  ],
  "trading_implication": "Candle Three Closure是Candle Two Closure缺失时的替代确认机制。价格触及关键水平未立即反转时，等待第三根K线打印以确认方向。形成C3 Closure后，可在第四根K线寻找入场机会，以第三根K线均衡点（0.5斐波那契位）作为目标区域，以受保护摆动点作为止损参考，并结合下位时间框架状态改变信号提升确认强度。",
  "common_mistakes": [
    "未确认前两根K线确实未形成二号收盘就直接使用三号收盘",
    "忽视第三根K线必须形成新的受保护摆动点的要求",
    "未确认存在高时间框架关键水平或兴趣点就交易C3 Closure",
    "将随机摆动点与C3 Closure混淆，忽视背景和上下文",
    "在第二根K线就预期反转，而不是等待第三根K线确认",
    "将三号收盘与下位时间框架的状态改变信号分离使用，降低确认强度",
    "未结合均衡点（EQ）来确定第四根K线的目标区域"
  ],
