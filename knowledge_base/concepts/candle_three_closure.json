{
  "card_id": "candle_three_closure",
  "type": "merged_concept",
  "canonical_term": "Candle Three Closure",
  "aliases": [
    "c3",
    "C3",
    "C3 Closure",
    "c3 closure",
    "Candle 3 Closure",
    "三号收盘"
  ],
  "school": "ICT",
  "definition": "A reversal confirmation pattern when candle two fails to close back inside candle one's range (invalid candle two closure). Candle three does not break candle two's high/low but closes through (engulfs) candle two's body in the opposing direction, forming a new protected swing at a higher timeframe point of interest. It anticipates candle four expansion toward a draw on liquidity.",
  "identification_rules": [
    "Confirm candle two did not form a valid candle two closure (did not close back inside candle one's range).",
    "Candle three does not break candle two's high or low.",
    "Candle three closes through (engulfs) the body of candle two in the opposing direction (bullish: close above candle two's body; bearish: close below candle two's body).",
    "The formation must occur at a valid higher-timeframe point of interest (e.g., swing high/low, fair value gap, equilibrium, order block) with proper separation from prior structure.",
    "An unmitigated draw on liquidity (e.g., external range liquidity, previous day high/low) exists in the direction of anticipated expansion.",
    "Candle three closure must form a new protected swing point.",
    "Confirmation occurs only after candle three closes; do not anticipate before the full 1-2-3 swing point is complete.",
    "After confirmation, mark the full range of candle three; candle four's wick is expected to form in the upper half (bullish) or lower half (bearish) of that range.",
    "Ideal candle two is a reversal candle with a large wick, not a small-bodied expansion candle.",
    "Upon closure, drop to a lower timeframe to find a change in state of delivery and continuation entry off a protected swing, rather than entering immediately."
  ],
  "trading_implication": "Candle three closure validates a reversal when candle two closure is absent, allowing anticipation of candle four expansion toward a draw on liquidity. After confirmation, drop to a lower timeframe to find a change in state of delivery and enter on a continuation off a protected swing, using candle three's range equilibrium as reference. Stop beyond the protected swing, target minimum 2R. Pattern invalid without a point of interest.",
  "common_mistakes": [
    "Acting before candle three closes or entering on candle three itself without waiting for a lower timeframe continuation signal.",
    "Taking a candle three closure without a valid point of interest or at a non-relevant swing high/low.",
    "Ignoring the requirement for an unmitigated draw on liquidity in the expansion direction.",
    "Confusing the pattern with a retracement or consolidation phase, failing to distinguish reversal from breakout.",
    "Treating a wick-through of candle two's body as sufficient, when only a full body close-through is valid.",
    "Trading setups where price has already reached equal highs/lows or failure swings, leaving no liquidity to target.",
    "Not confirming a change in state of delivery or protected swing on lower timeframe, and catching the initial reversal instead.",
    "Failing to confirm that candle two did not form a valid candle two closure before using candle three closure.",
    "Using candle three closure without a higher timeframe key level or point of interest.",
    "Confusing random swing points with candle three closure, ignoring context and background.",
    "Expecting reversal on candle two instead of waiting for candle three confirmation.",
    "Not combining candle three closure with lower timeframe change in state of delivery, reducing confirmation strength.",
    "Not using equilibrium (EQ) to determine candle four target area."
  ],
