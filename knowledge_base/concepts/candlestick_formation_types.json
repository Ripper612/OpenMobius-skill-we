{
  "card_id": "candlestick_formation_types",
  "type": "merged_concept",
  "canonical_term": "Candlestick Formation Types",
  "aliases": [
    "k线形成方式",
    "K线形成方式",
    "蜡烛线形态类型"
  ],
  "school": "The Strat",
  "definition": "K线相对于前一根K线的三种形成方式：盘整（未突破前一根K线高低点）、单边突破（突破一侧流动性）、双边突破（同时突破买卖方流动性）。",
  "identification_rules": [
    "盘整：当前K线的高点未超过前一根K线的高点（买方流动性），低点未低于前一根K线的低点（卖方流动性）",
    "单边突破：当前K线突破前一根K线的一侧（高点或低点），但未突破另一侧",
    "双边突破：当前K线同时突破前一根K线的高点和低点，即突破买卖双方流动性"
  ],
  "trading_implication": "识别K线形成方式用于预测价格后续走向。若非盘整状态，价格倾向于向前一根K线的高点或低点移动，或同时向两侧移动。这帮助交易者预期价格可能触及的流动性水平，用于框架化流动性吸收或反转点。",
  "common_mistakes": [
    "未明确说明"
  ],
