{
  "card_id": "change_in_the_state_of_delivery",
  "type": "merged_concept",
  "canonical_term": "Change in the state of delivery",
  "aliases": [
    "CISD",
    "CSD",
    "State of Delivery Change",
    "opposing candles",
    "reversal sequence completion",
    "state of delivery confirmation",
    "state of delivery shift",
    "交付状态改变",
    "市场结构转变（在伦敦反转背景下）",
    "状态交付改变",
    "状态改变"
  ],
  "school": "ICT",
  "definition": "价格收盘突破形成摆动高/低点的一系列同向K线序列（或单根K线的开盘价），标志市场从卖方交付模式转向买方交付模式（或反之）。先于市场结构转变发生，是趋势反转或延续的中期确认信号，常伴随位移和公允价值缺口形成。",
  "identification_rules": [
    "识别形成摆动高点或低点的一系列同向收盘K线序列（如连续下跌收盘或连续上涨收盘）",
    "标记该序列的关键价格水平：开盘价或K线主体边界",
    "确认价格收盘完全穿过该序列（收盘价必须穿过，仅触及不算），形成闭合突破",
    "看涨CSD：价格收盘突破一系列下跌K线序列上方；看跌CSD：价格收盘突破一系列上涨K线序列下方",
    "CSD不要求突破摆动高/低点本身，仅需收盘穿过形成该摆动点的K线序列开盘价或主体",
    "可在任意时间框架（日线、4小时、1小时、15分钟、5分钟等）识别，遵循分形原理",
    "CSD应出现在摆动点（Candle 2）处确认，而非后续K线",
    "有效CSD通常伴随明显位移（Displacement）和公允价值缺口（FVG）产生",
    "可结合SMT（相关资产分歧）验证：若突破前形成SMT，则CSD有效性更强",
    "高时间框架CSD确认后，可在低时间框架寻找对应CSD作为精确入场点",
    "CSD形成后，该K线序列转变为订单块，成为新的支撑或阻力区域",
    "在反转序列中，CSD通常在Inversion（反转）之后出现，作为第三步确认"
  ],
  "trading_implication": "CSD是多时间框架交易的关键确认信号，比MSS提供更早的入场机会。CSD确认后，交易者可在后续回测至公允价值缺口或订单块时寻找入场，以受保护摆动点（Protected Swing）设置止损，以外部流动性为目标。CSD还可触发斐波那契投影分析（基于操纵腿），生成-1至-4.5标准差目标位。需结合高时间框架偏差逐级确认，避免逆势交易。",
  "common_mistakes": [
    "将单根K线的突破误认为CSD，忽视需要一系列同向收盘K线序列的要求",
    "仅凭影线穿破关键水平就判断CSD成立，未等待收盘确认",
    "在CSD完全形成前过早入场，被诱导（Inducement）扫出止损",
    "将CSD与MSS混淆：CSD关注收盘穿过K线序列开盘价，MSS关注突破摆动高/低点",
    "忽视CSD可能是虚假信号，价格形成CSD后仍可能继续原趋势",
    "未在多个时间框架逐级确认CSD，直接在低时间框架入场增加虚假信号风险",
    "在高时间框架缺乏偏差或关键水平背景的情况下单独使用CSD",
    "未确认价格是否真正触及高时间框架关键水平（PD Array）就判断CSD成立",
    "混淆CSD与Candle 3 Closure，两者属于不同形态，不应用于同一交易逻辑",
    "在大操纵腿情况下仍期望价格到达-2或-2.5标准差目标，忽视范围过大的现实",
    "同时标注多个PD Array（CSD、FVG、Breaker Block等）导致图表混乱，难以确定明确入场点",
    "在CSD形成后立即入场，而不等待延续确认或受保护摆动点形成",
    "忽视CSD形成的时间点，K线末期形成的CSD不支持该K线内的扩张，应等待下一根K线"
  ],
