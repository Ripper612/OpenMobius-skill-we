{
  "card_id": "consolidation_reversal",
  "type": "merged_concept",
  "canonical_term": "Consolidation Reversal",
  "aliases": [
    "Consolidation Reversal Weekly Profile",
    "consolidation reversal weekly profile"
  ],
  "school": "ICT",
  "definition": "A weekly profile where Monday, Tuesday, and Wednesday form a consolidation range, Thursday manipulates that range and reverses (typically a candle 2 closure sweeping Monday's high or low), and Friday expands in the new direction toward a higher time frame key level or average daily range.",
  "identification_rules": [
    "Confirm that neither a classic expansion nor a midweek reversal has formed by Wednesday — price must be consolidating through the first three days.",
    "Verify Monday, Tuesday, and Wednesday have all traded within a defined range with no directional expansion.",
    "On Thursday, look for a sweep of Monday's high (bearish setup) or Monday's low (bullish setup) followed by a close back inside the previous day's range — a candle 2 closure.",
    "Drop to the hourly time frame and confirm a change in state of delivery inside Thursday's range (price closes through the series of opposing candles that formed the Thursday extreme).",
    "Anticipate Friday as the continuation/expansion day targeting the opposite side of the consolidation range, failure swings, or a higher time frame key level."
  ],
  "trading_implication": "Used as a weekly bias framework when neither classic expansion nor midweek reversal sets up. Preferred execution is Friday continuation rather than catching Thursday's reversal directly; entries are taken on the hourly time frame after a confirmed change in state of delivery inside Thursday's range. Targets are the opposite side of the consolidation range, prior failure swings, or a higher time frame PD array, capped by the average daily range.",
  "common_mistakes": [
    "Calling a low/high formed on Wednesday without waiting for Thursday — a bearish expansion candle on Wednesday is not trustworthy as a reversal point.",
    "Trading Thursday's reversal day directly instead of waiting for Friday's continuation, which is the preferred expansion day.",
    "Entering Friday without confirming an hourly change in state of delivery inside Thursday's range.",
    "Confusing a doji or indecision candle taking out both sides of the range with directional information."
  ],
