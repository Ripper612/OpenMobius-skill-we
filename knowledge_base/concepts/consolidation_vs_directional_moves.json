{
  "card_id": "consolidation_vs_directional_moves",
  "type": "merged_concept",
  "canonical_term": "Consolidation vs Directional Moves",
  "aliases": [
    "Candle Range Behaviors",
    "candle range behaviors",
    "Three Candlestick States",
    "three candlestick states"
  ],
  "school": "Price Action",
  "definition": "A candlestick can either consolidate (fail to take out the prior candle's high or low), make a directional move (take out one side), or take out both sides. If not consolidating, price is likely to target the previous candle's high, low, or both, serving as draw on liquidity or reversal points.",
  "identification_rules": [
    "If the current candle's high is lower than the prior candle's high and its low is higher than the prior candle's low, it is consolidating.",
    "If the current candle takes out the prior candle's high but not its low, it is a bullish directional move.",
    "If the current candle takes out the prior candle's low but not its high, it is a bearish directional move.",
    "If the current candle takes out both the prior candle's high and low, it is a double-sided move (often an outside bar)."
  ],
  "trading_implication": "Unless price is consolidating, anticipate a move toward the prior candle's high, low, or both. These levels act as liquidity targets, providing potential entry, exit, or reversal zones. This principle applies across all timeframes from monthly to daily candles.",
  "common_mistakes": [
    "Misidentifying a small indecision candle as consolidation when it can still break one side.",
    "Assuming a directional move will continue beyond the prior extreme without other confirmations."
  ],
