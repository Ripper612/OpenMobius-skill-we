{
  "card_id": "consumer_price_index",
  "type": "merged_concept",
  "canonical_term": "Consumer Price Index",
  "aliases": [
    "CPI",
    "cpi"
  ],
  "school": "ICT",
  "definition": "A high-impact macroeconomic news release at 8:30 ET that elevates volatility and expands price ranges. The preceding day often produces an indecision candle (Seek and Destroy profile) as participants withhold commitment. Post-release, it serves as a catalyst for SMT divergence setups between correlated assets.",
  "identification_rules": [
    "Check the economic calendar: if a CPI release is scheduled for the following day, classify the current session as a probable Seek and Destroy / indecision profile day.",
    "On the daily chart, look for a candle where open and close are at approximately the same price level with extended wicks in both directions, consistent with an indecision candle.",
    "On lower time frames, confirm by observing London sweeping both sides of the Asia range without sustaining directional expansion, then New York oscillating within the same range.",
    "Identify CPI as the scheduled 8:30 ET economic release on the calendar before trading the session.",
    "After the release, compare correlated assets (e.g., NQ vs ES) for divergence where one sweeps a high/low into a fair value gap while the other does not.",
    "Look for a high-low-higher high-lower low sequence post-release to confirm a breaker block formation around the divergence."
  ],
  "trading_implication": "Avoid entries before CPI release. For the preceding day, fade moves back into the established range targeting equilibrium. Post-release, wait for SMT divergences between correlated assets; place stops above high resistance liquidity (a high that ran another high) rather than directly above the breaker block. Target equal lows or prior liquidity pools. Lower time frame entries (1-minute) can be used after the initial setup to achieve minimum 2R by entering on retracements into fair value gaps or order blocks.",
  "common_mistakes": [
    "Attempting to trade directional breakouts or expansions on a day preceding CPI, when the market is likely to produce an indecision profile instead.",
    "Ignoring the economic calendar and misclassifying a CPI-driven indecision day as a trending profile.",
    "Taking entries before the CPI release rather than waiting for post-release confirmation.",
    "Placing stops directly above a breaker block during CPI volatility instead of on high resistance liquidity.",
    "Entering blindly on an SMT divergence without waiting for displacement or a structural setup to confirm the reversal."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
