{
  "card_id": "continuation_setup",
  "type": "merged_concept",
  "canonical_term": "Continuation Setup",
  "aliases": [
    "continuation day",
    "Continuation Day",
    "Daily Continuation",
    "daily continuation"
  ],
  "school": "ICT",
  "definition": "A daily framework where price opens, trades lower (bullish) or higher (bearish) first while respecting the previous day's equilibrium, then expands through the previous day's high or low in the direction of the higher time frame bias, confirmed by a lower time frame change in state of delivery.",
  "identification_rules": [
    "Establish a higher time frame bias first (e.g., ideal candle 2 or candle 3 closure forming a new protected swing).",
    "Mark out the previous day's equilibrium (EQ) and the previous day's high/low on the daily chart.",
    "For a bullish continuation: price must open, trade lower first, respect EQ (no hourly closure below EQ when using daily-hourly pairing), then trade through previous day high.",
    "For a bearish continuation: price must open, trade higher first, respect EQ from below, then trade through previous day low.",
    "Wait for a lower time frame change in state of delivery to confirm the wick of the higher time frame candle before entering.",
    "Use hourly or 30-minute confirmation during Asia/London, and 5-minute or 15-minute during New York.",
    "Price can form its high/low below/above EQ without touching it — look for points of interest (e.g., fair value gaps) near EQ instead."
  ],
  "trading_implication": "The continuation setup provides an aligned entry method to ride a higher time frame trend by entering after the daily wick forms against the bias. Entries are taken at the lower time frame CISD following the open's counter-trend move into EQ or a discount/premium POI. Expansion potential beyond previous day high/low depends on the wick size of the reversal candle: a small wick supports significant expansion, while a large wick limits range, with daily open serving as a more conservative target.",
  "common_mistakes": [
    "Pattern trading the setup without aligning it with a higher time frame bias.",
    "Entering on a candle closure alone rather than waiting for a lower time frame change in state of delivery.",
    "Expecting full expansion beyond previous day high/low when the reversal candle has a large wick.",
    "Treating a closure below EQ on the hourly (when pairing daily-hourly) as still valid for continuation — it is less probable.",
    "Assuming a protected swing will always hold; once it hits liquidity, the protected swing itself can be swept before the true move."
  ],
