{
  "card_id": "correlated_pairs",
  "type": "merged_concept",
  "canonical_term": "Correlated Pairs",
  "aliases": [
    "Correlated Assets",
    "correlated assets",
    "correlated triad",
    "Correlated Triad",
    "关联货币对",
    "相关资产对"
  ],
  "school": "ICT",
  "definition": "Two or more assets expected to move in the same direction due to shared underlying drivers (e.g., ES and NQ, EUR/USD and GBP/USD). Similar swing structure is anticipated; structural divergence between correlated pairs is identified as an SMT. Inversely correlated pairs show mirrored structure.",
  "identification_rules": [
    "Identify two assets that share an underlying driver (e.g., ES and NQ are both US equity indices; EUR/USD and GBP/USD are both quoted against the dollar).",
    "For positively correlated pairs, confirm that swing highs and swing lows on both assets occur at approximately the same time and direction (low matches low, higher low matches higher low).",
    "For inversely correlated pairs (e.g., EUR/USD vs DXY), confirm that a high on one corresponds to a low on the other, and a higher high on one corresponds to a lower low on the other.",
    "A divergence in the expected structural relationship (one makes a higher high while the other does not, or in inverse pairs one makes a higher high while the other fails to make a lower low) defines an SMT.",
    "Compare swing points at matching timestamps using vertical alignment or dual-panel chart layout.",
    "Verify that both assets form similar structures (e.g., simultaneous lows and highs) on the same timeframe."
  ],
  "trading_implication": "Correlated pairs are the foundation for SMT analysis, used as confluence to confirm reversals rather than as a standalone signal. Align divergence with higher timeframe levels (session highs/lows, previous day highs/lows, fair value gaps) to increase reversal probability. Choose between the stronger asset (made the higher high, providing high resistance liquidity) or the weaker asset (failed to make the higher high) based on higher timeframe setup and relative strength. SMT alone is not a trade signal; combine with other structures like order blocks or fair value gaps.",
  "common_mistakes": [
    "Treating every SMT divergence as a tradable signal without aligning it with a higher timeframe level or pre-existing idea.",
    "Forgetting that inversely correlated pairs require flipped structure comparison (high vs low, not high vs high).",
    "Searching for SMTs everywhere rather than focusing on session highs/lows, previous day high/low, and HTF PD arrays.",
    "Confusing correlated pairs by selecting assets that are not actually related."
  ],
  "related_concepts": [
