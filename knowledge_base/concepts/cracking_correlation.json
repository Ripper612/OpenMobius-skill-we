{
  "card_id": "cracking_correlation",
  "type": "merged_concept",
  "canonical_term": "Cracking Correlation",
  "aliases": [
    "Candle 2/Candle 3 SMT",
    "candle 2/candle 3 smt",
    "Kraken Correlation",
    "kraken correlation",
    "Kraken SMT"
  ],
  "school": "ICT",
  "definition": "An SMT divergence between two correlated assets, where one asset's candle 3 sweeps candle 2's high/low (failure swing) while the correlated asset's candle 3 does not, confirming a reversal at a key level. It often serves as the second stage of a two-stage SMT sequence.",
  "identification_rules": [
    "Identify two highly correlated assets (e.g., NQ/YM, HO/RB, GC/XAUGBP) aligned on the same time frame.",
    "Locate candle 2 and candle 3 on both assets after price has reached a key level (fair value gap, range high/low, or external range liquidity).",
    "Confirm that one asset's candle 3 sweeps (runs through) candle 2's high/low creating a failure swing while the correlated asset's candle 3 does not take out the corresponding swing.",
    "Validate that this divergence is paired with a point of interest; without a key level it is not actionable.",
    "Often used as the second stage of a two-stage SMT sequence, following a first-stage SMT or PSP at the key level.",
    "Observe that the pattern appears after the first-stage SMT, as part of a two-stage SMT sequence."
  ],
  "trading_implication": "Cracking Correlation acts as a high-probability reversal confirmation between candles 2 and 3 at a key level. After it forms, traders look to trade the continuation away from the external range toward the opposing side of the range as the target. It is most powerful when stacked into a two-stage SMT sequence (key-level SMT plus PSP plus cracking correlation between swing points), which the speaker identifies as the highest probability reversal signature in the framework.",
  "common_mistakes": [
    "Interpreting any candle-2/candle-3 divergence as a reversal without confirming both assets are at a key level or POI.",
    "Mistaking a continuation PSP (where both assets are expanding toward a draw on liquidity and one runs a prior candle low/high as part of retracement) for a reversal cracking correlation — narrative and draw on liquidity must be considered.",
    "Failing to wait for the failure swing to actually print on one asset before entering, instead anticipating it at equal highs/lows.",
    "Confusing Cracking Correlation with ordinary PSP, failing to recognize its special status as a higher-probability confirmation signal."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
