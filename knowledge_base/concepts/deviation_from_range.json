{
  "card_id": "deviation_from_range",
  "type": "merged_concept",
  "canonical_term": "Deviation from Range",
  "aliases": [
    "Range Breakout",
    "range breakout",
    "Range Deviation",
    "range deviation"
  ],
  "school": "ICT",
  "definition": "价格突破盘整区间的高点或低点后，随后回归至该区间内的价格行为。在Seek and Destroy模式中标志着潜在的交易机会。",
  "identification_rules": [
    "识别一个明确的盘整区间（由高点和低点界定）",
    "观察价格是否突破该区间的上边界或下边界",
    "确认价格在突破后是否回归至区间内部",
    "标记每次突破并回归的位置作为偏离点"
  ],
  "trading_implication": "偏离点标识了高概率的交易入场区域。交易者在识别偏离后，可以预期价格向三个目标位移动：(1)区间均衡点(EQ)、(2)最优交易入场点(OTE，使用斐波那契回撤)、(3)区间另一侧的流动性(买方或卖方流动性)。这些偏离创造了可交易的结构，特别是在缺乏高时间框架方向性的盘整中。",
  "common_mistakes": [
    "未能确认价格是否真正回归至区间内，导致误判偏离点",
    "在超大位移蜡烛出现时仍按常规偏离处理，可能导致范围突破而非回归",
    "忽视多个偏离的累积效应，未能识别范围可能被真正突破的信号"
  ],
