{
  "card_id": "drawdown",
  "type": "merged_concept",
  "canonical_term": "Drawdown",
  "aliases": [
    "Drawdown Limit",
    "drawdown limit",
    "Max Drawdown",
    "max drawdown"
  ],
  "school": "Risk Management",
  "definition": "The maximum loss allowance on a prop firm account before the account is failed. On futures prop firm accounts, the drawdown amount—not the nominal account size—represents the true risk capital available and should be the basis for position sizing calculations.",
  "identification_rules": [
    "Identify the prop firm's stated maximum loss limit (e.g., $1,500 drawdown on a 25K account) as the drawdown figure.",
    "Treat the drawdown amount, not the nominal account size, as the actual capital at risk.",
    "Calculate risk per trade as a percentage of the drawdown amount rather than as a percentage of the nominal account size.",
    "Target a risk per trade between 7% and 10% of the drawdown, allowing 10–15 consecutive losing trades before the account is blown."
  ],
  "trading_implication": "Drawdown determines real position sizing on prop firm accounts. Risking 1% of a 25K nominal account when the drawdown is only $1,500 actually equals ~17% of true risk capital, blowing the account in 6–7 losses. Instead, set risk at 7–10% of the drawdown to survive 10–15 consecutive losses during evaluation. Once funded, risk is typically lowered to build a larger cushion. The same principle applies to Forex prop firms with different numbers.",
  "common_mistakes": [
    "Sizing position as a percentage of the nominal account size (e.g., 25K) instead of the drawdown amount, leading to oversized risk.",
    "Risking 1% of the nominal account when it actually equates to ~17% of the drawdown, which blows the account after only 6–7 losing trades.",
    "Failing to lower risk after passing the evaluation phase, missing the opportunity to build a cushion on the funded account."
  ],
