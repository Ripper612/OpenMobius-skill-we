{
  "card_id": "equal_highs_and_equal_lows",
  "type": "merged_concept",
  "canonical_term": "Equal Highs and Equal Lows",
  "aliases": [
    "Clustered Highs/Lows",
    "clustered highs/lows",
    "relative equal highs",
    "Relative Equal Highs",
    "Relative Equal Lows",
    "relative equal lows",
    "Relatively Equal Highs/Lows",
    "relatively equal highs/lows",
    "相同价格水平的摆动点"
  ],
  "school": "ICT",
  "definition": "两个或多个摆动高点或低点价格水平相对接近或聚集在同一区域形成的相等高低点。未被扫除时代表外部流动性汇集区域，是价格后续运动的目标水平；价格倾向于回测并突破这些区域以扫取流动性。",
  "identification_rules": [
    "在图表上识别两个或多个摆动高点或低点，确认其价格水平相对接近或聚集在同一区域（而非单个突出的摆动点）",
    "检查后续摆动点是否在前一摆动高/低点的相近价格水平形成，或多个摆动点是否集中于同一价格区域",
    "确认这些相等水平是否已被价格扫除（突破）：未被扫除的标记为有效流动性目标，已被扫除的不再视为有效目标",
    "观察价格在接近这些水平时是否出现回测、突破或反弹行为",
    "可在多个时间框架（如1分钟、5分钟、15分钟等）上识别并交叉验证"
  ],
  "trading_implication": "未被扫除的相等高低点是寻找 Draw on Liquidity 的关键外部流动性目标。做多时可将相等高点作为利润目标，做空时可将相等低点作为目标。价格接近相等高点时可能面临阻力或突破机会，接近相等低点时可能获得支撑或进一步下跌。结合位移（Displacement）分析判断价格是否真正突破，也可与会话高低点、前日高低点等流动性水平结合确定反转点。",
  "common_mistakes": [
    "将已被扫除的相等高低点误认为仍是有效目标区域",
    "将单个突出的摆动点误认为相等高低点，应确保至少两个摆动点在相近价格水平",
    "未在多个时间框架上验证相等水平的有效性，导致误判流动性位置",
    "忽视价格是否真正发生位移（Displacement）突破这些水平，仅凭价格接近就做出交易决策",
    "混淆相等高低点与其他流动性来源（如 FVG、Order Block），未能正确排列目标优先级",
    "忽视相等高低点作为流动性汇集区的意义，未将其纳入价格目标或反转框架"
  ],
