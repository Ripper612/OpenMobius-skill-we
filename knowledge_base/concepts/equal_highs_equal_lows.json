{
  "card_id": "equal_highs_equal_lows",
  "type": "merged_concept",
  "canonical_term": "Equal Highs / Equal Lows",
  "aliases": [
    "Relatively Equal Highs",
    "Relatively Equal Lows",
    "relatively equal lows",
    "相同高点/相同低点",
    "等高点/等低点"
  ],
  "school": "ICT",
  "definition": "Equal highs are two or more swing highs at similar price levels forming a buy-side liquidity cluster; equal lows are two or more swing lows forming a sell-side liquidity cluster. Price tends to sweep these levels to trigger stop orders, often aligning with standard deviation projections from PD arrays.",
  "identification_rules": [
    "Identify two or more swing highs (equal highs) or swing lows (equal lows) at approximately the same price level, separated by time, forming a visible horizontal cluster.",
    "Confirm the cluster represents a concentration of resting stop orders (buy stops above equal highs, sell stops below equal lows).",
    "These levels often coincide with standard deviation projections (e.g., 2-2.5 or 4 standard deviations) from PD arrays, providing confluence.",
    "Equal lows can serve as 'low hanging fruit', indicating price may easily reach that area."
  ],
  "trading_implication": "Equal highs/lows act as draw-on-liquidity targets. Price is expected to sweep these levels to trigger stop orders, providing liquidity for smart money to reverse or continue. They serve as points of interest for entries and profit targets, often paired with standard deviation projections and order blocks for entry and stop placement.",
  "common_mistakes": [
    "Mistaking isolated single highs/lows for equal highs/lows; requires multiple touches at the same level.",
    "Failing to validate equal highs/lows with standard deviation projections, reducing confluence."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
