{
  "card_id": "equal_lows",
  "type": "merged_concept",
  "canonical_term": "Equal Lows",
  "aliases": [
    "Relatively Equal Lows",
    "Sell Stops",
    "stacked lows",
    "Stacked Lows",
    "相等低点",
    "等低"
  ],
  "school": "ICT",
  "definition": "Two or more swing lows at approximately the same price level, forming a horizontal cluster of sell-side liquidity (resting sell stops). Price is drawn to sweep these lows before reversing or continuing, with the lowest low often being the primary liquidity target.",
  "identification_rules": [
    "Locate two or more distinct swing lows at approximately the same horizontal price level, forming a visible cluster.",
    "Confirm these lows represent sell-side liquidity: the area just below them is a pool of resting sell stops.",
    "Verify the lows are separate swing points with clear separation; stacked lows with minimal separation indicate only the lowest low is the relevant liquidity target.",
    "Ensure the equal lows sit below current price and are an accessible downside target.",
    "Confirm significance by pairing with higher time frame context (e.g., prior session highs/lows, Asia range) or a nearby opposing point of interest such as a fair value gap.",
    "Look for repeated failures to displace below these lows (e.g., three drives into the level) as confirmation of a liquidity pool.",
    "Once price sweeps the lowest equal low, consider that liquidity taken; subsequent swing points near that level are failure swings.",
    "Apply a multi-candle lookback on higher time frames to ensure the equal lows are within the relevant trading period and not stale.",
    "Equal lows can be identified across multiple time frames (e.g., 1H, 4H, daily) for validation."
  ],
  "trading_implication": "Equal lows are a draw on liquidity. Price sweeps below them to trigger sell stops before reversing or continuing. They serve as targets for shorts and reversal entry points for longs after a liquidity sweep, confirmed by a change in state of delivery (e.g., closure above a down candle) and lower-timeframe shift like a protected swing. Confluence with higher-timeframe PD arrays (fair value gaps), prior session levels, or standard deviation projections strengthens the setup. Once swept, the lows become manipulated levels; avoid trading failure swings near them.",
  "common_mistakes": [
    "Entering before the equal lows are swept, without waiting for the liquidity grab and subsequent reversal confirmation.",
    "Trading away from a higher failure swing while the lowest equal low remains unswept, or trading after the objective has been hit without waiting for a new swing point.",
    "Treating equal lows as a reversal level rather than primarily a liquidity target that price is likely to sweep.",
    "Failing to distinguish stacked equal lows with minimal separation from independent swing lows with proper range separation.",
    "Assuming continuation lower when price repeatedly fails to displace below equal lows, instead of recognizing consolidation and potential reversal.",
    "Ignoring higher-time-frame context and confluence with opposing PD arrays when assessing significance.",
    "Acting on equal-low sweeps that occur outside of a kill zone or without a supporting point of interest.",
    "Not validating equal lows across multiple time frames, leading to false signals.",
    "Confusing equal lows with single support levels, overlooking their role as major trading targets."
  ],
