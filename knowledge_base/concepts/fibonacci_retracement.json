{
  "card_id": "fibonacci_retracement",
  "type": "merged_concept",
  "canonical_term": "Fibonacci Retracement",
  "aliases": [
    "0.5 Fibonacci Level",
    "Fib",
    "fib",
    "Fibonacci Retracement Tool",
    "fibonacci retracement tool",
    "OTE Fib",
    "ote fib",
    "斐波那契回撤"
  ],
  "school": "ICT",
  "definition": "A charting tool measuring retracement levels within a swing range, configured with levels 0.5, 0.62, 0.705, 0.79, and 1.0. The 0.5 level marks equilibrium between discount and premium zones. The 0.62–0.79 zone (midpoint 0.705) is the Optimal Trade Entry (OTE) zone for retracement entries. Also applied to price intervals like Breaker Blocks and FVGs to mark the 0.5 midpoint as additional support/resistance.",
  "identification_rules": [
    "Configure the Fibonacci retracement tool with levels 0.5, 0.62, 0.705, 0.79, and 1.0.",
    "Identify a confirmed swing high (with lower highs on both sides) and swing low (with higher lows on both sides) as anchor points.",
    "For a bearish scenario, drag the tool from swing high down to swing low (0 at high, 1 at low); for a bullish scenario, drag from swing low up to swing high (0 at low, 1 at high).",
    "Mark the 0.5 level as the equilibrium boundary between discount (below 0.5) and premium (above 0.5).",
    "Mark the zone from 0.62 to 0.79, including the 0.705 midpoint, as the Optimal Trade Entry (OTE) zone.",
    "On Breaker Blocks, draw Fibonacci from the candle close to the low/high to mark the 0.5 level, especially when the candle has a long wick.",
    "On identified Fair Value Gaps (FVGs) or price intervals, apply Fibonacci to mark the 50% geometric midpoint.",
    "The 0.5 Fib level should be used in conjunction with the Breaker Block's Mean Threshold or Order Block open price to refine entry."
  ],
  "trading_implication": "After a swing range forms, wait for price to retrace into the OTE zone (0.62–0.79) before seeking entries. In a bearish range, look for short entries targeting sellside liquidity below; in a bullish range, look for long entries targeting buyside liquidity or FVG above. The 0.705 midpoint is a high-probability reaction level. For FVGs, entering at the midpoint reduces risk compared to the edge. Combine OTE with PD Array (FVG, Order Block) for confluence. If Order Block open is outside OTE, use its Mean Threshold instead.",
  "common_mistakes": [
    "Drawing the tool before both swing high and swing low are confirmed; the retracement must wait until the range is fully formed.",
    "Drawing in the wrong direction for the scenario (high-to-low is for bearish, low-to-high is for bullish).",
    "Using only the candle body without considering the wick when calculating the 0.5 level on Breaker Blocks, leading to inaccurate levels.",
    "Not combining the 0.5 Fib level with Mean Threshold, Order Block open, or other Breaker Block features.",
    "Expecting a reaction after price has already crossed the 0.5 level; validity is confirmed when price touches but does not cross.",
    "Entering at equilibrium (0.5) instead of using discount/premium zones, resulting in poor risk-reward.",
    "Identifying only a single range and ignoring nested ranges within the price action.",
    "Failing to update the Fibonacci range dynamically as price makes new highs/lows.",
    "Forcing OTE entry when the Order Block open is not within the OTE zone, ignoring the Mean Threshold alternative."
  ],
