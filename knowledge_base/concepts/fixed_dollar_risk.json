{
  "card_id": "fixed_dollar_risk",
  "type": "merged_concept",
  "canonical_term": "Fixed Dollar Risk",
  "aliases": [
    "fixed percentage risk",
    "Fixed Percentage Risk"
  ],
  "school": "Risk Management",
  "definition": "A position sizing method where the same dollar amount (or account percentage) is risked on every trade, achieved by adjusting contract or lot size based on the stop distance so each loss equals 1R regardless of stop size.",
  "identification_rules": [
    "Define a fixed dollar (or percentage) risk amount per trade, e.g. $1,000 per trade on a given account.",
    "For each trade, calculate contracts as: defined risk ÷ (value per point × stop size in points).",
    "Use micro contracts (1/10th of a mini) when the calculated size is fractional to approximate the target risk more precisely.",
    "Round down to the nearest whole contract/micro when fractional sizing is not possible.",
    "Verify every trade's dollar risk equals 1R before execution, regardless of whether the stop is wider or tighter than prior trades."
  ],
  "trading_implication": "Fixed dollar risk is required for the win-rate × risk-to-reward profitability table to hold true. By adjusting contract size per trade, a winning trade fully recovers prior losses at the expected R multiple, whereas inconsistent sizing can leave the account at breakeven or negative even when the win rate and R:R are met. It is the preferred sizing method over fixed contract sizing because it preserves R consistency across trades with different stop distances.",
  "common_mistakes": [
    "Using a fixed contract size across trades with different stop distances, producing inconsistent dollar risk and breaking the win-rate/R:R correlation.",
    "Risking different dollar amounts per trade (e.g. $2,000 on one trade and $1,000 on the next), which can turn an expected 1R profit into breakeven or worse.",
    "Failing to use micro contracts when fractional mini-contract sizing is needed, leaving the actual risk far from the intended R.",
    "Not adjusting the TradingView risk/reward tool's lot size setting (e.g. leaving Forex settings for a futures trade), producing incorrect quantity outputs."
  ],
