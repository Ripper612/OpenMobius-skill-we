{
  "card_id": "hammer_shooter_candle",
  "type": "merged_concept",
  "canonical_term": "Hammer/Shooter Candle",
  "aliases": [
    "Hammer Candle",
    "Shooter Candle",
    "shooter candle",
    "Shooting Star",
    "shooting star",
    "射手形K线"
  ],
  "school": "ICT",
  "definition": "A higher-time-frame candlestick pattern formed when price aggressively sweeps a low (hammer) or high (shooter) and swiftly returns into the prior range, creating a long wick and signaling potential reversal without a structural shift.",
  "identification_rules": [
    "On a higher time frame, price aggressively sweeps a prior low (for hammer) or high (for shooter), moving well beyond it.",
    "Price then aggressively returns into the previous range, leaving a long lower wick (hammer) or long upper wick (shooter) with a small real body.",
    "The candle closes well within the prior range, indicating rejection of the extreme level.",
    "No market structure shift is required; the pattern itself signals a potential reversal.",
    "For shooter: price first aggressively breaks above a range high, then falls back into the range on the same or adjacent candle."
  ],
  "trading_implication": "This pattern enables reversal entries without waiting for a break of structure. After the hammer/shooter closes, traders look for a point of interest (BPR, FVG, or box setup) to enter, place stops beyond the wick extreme, and target internal liquidity levels such as previous highs/lows. In multi-timeframe analysis, it can serve as a trigger for lower-timeframe entries, especially combined with FVG or OB.",
  "common_mistakes": [
    "Misidentifying a normal wick as a hammer/shooter without the aggressive sweep and return into the range.",
    "Entering before the hammer/shooter candle closes, thus risking a false rejection."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "First card (Education - ICT) defined shooter only and used Price Action school; second card (ICT Updated) defined both hammer and shooter under ICT school. Majority school is ICT. The first card's identification rule about 'price first aggressively breaks above a range high' is added to the union.",
