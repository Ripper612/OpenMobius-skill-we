{
  "card_id": "higher_time_frame_level",
  "type": "merged_concept",
  "canonical_term": "Higher Time Frame Level",
  "aliases": [
    "HTF Level",
    "高时间框架水平"
  ],
  "school": "ICT",
  "definition": "在更高时间周期（日线、周线等）上形成的摆动高点、摆动低点或公允价值缺口。具有更强的市场反应力度，是确认市场结构转变的必要前置条件——价格须先参与该水平，方可寻找可交易的结构设置。",
  "identification_rules": [
    "在日线、周线等高时间框架上识别前期摆动高点或摆动低点",
    "识别高时间框架上形成的公允价值缺口（如 Daily FVG）",
    "确认该摆动高/低点与前一个同级别摆动点之间具有充分的分离度（separation）",
    "使用分形回溯周期：日线图回溯3个月，小时图回溯3天，以此类推",
    "在低时间框架图表上观察价格是否触及或扫荡该高时间框架水平",
    "确认价格在该水平处形成反应（如反弹、回调或扫荡）后，再考虑结构转变的有效性"
  ],
  "trading_implication": "高时间框架水平是寻找交易设置的前置条件，提供最强的反转和结构转变信号。价格必须先在低时间框架上参与（接触或扫荡）该水平，才能确认市场结构转变的有效性，进而形成可交易的设置（如 OB、FVG、Breaker Block 等）。应优先在 HTF 水平处寻找模型形成，而非随机高低点。",
  "common_mistakes": [
    "未确认价格是否真正参与了高时间框架水平，就直接寻找结构转变设置",
    "只关注当前时间框架的摆动点，忽视其在更高时间框架上的地位",
    "将低时间框架的局部高低点误认为高时间框架水平",
    "交易与前一个同级别摆动点缺乏充分分离度的水平，导致反转信号不可信",
    "回溯周期设置不当，未按分形原理调整（如在小时图上仍回溯3个月而非3天）"
  ],
