{
  "card_id": "higher_time_frame_point_of_interest",
  "type": "merged_concept",
  "canonical_term": "Higher Time Frame Point of Interest",
  "aliases": [
    "HTF POI",
    "htf poi",
    "高时间框架兴趣点"
  ],
  "school": "ICT",
  "definition": "A significant PD array (high, low, fair value gap, or order block) on a higher time frame expected to attract price. Combined with an aggressive short-term liquidity sweep and reversal, it enables entry without waiting for a market structure shift, using a BPR, box setup, or OTE retracement.",
  "identification_rules": [
    "Locate a prominent PD array (high, low, FVG, OB) on a higher time frame (e.g., 15-minute or 1-hour).",
    "Wait for price to reach the HTF POI and aggressively sweep a short-term high or low at that level.",
    "Price must then aggressively move back into the prior range, creating a wick (hammer or shooting star) on the higher time frame.",
    "Confirm no close beyond the HTF POI on the higher time frame, indicating failure to displace.",
    "Enter on a lower time frame at a BPR, box setup, or OTE (discount/premium) within the retracement.",
    "Place stop beyond the swept short-term high/low and target opposing liquidity or internal range highs/lows."
  ],
  "trading_implication": "Allows early entry in reversals by combining a higher time frame level with a short-term liquidity sweep and aggressive reversal, bypassing the need for a confirmed MSS. This reduces the risk of missing moves and provides high-probability setups when the aggressive reversal is clear.",
  "common_mistakes": [
    "Entering without confirming the aggressive move back into the range; mistaking a shallow sweep for a genuine reversal.",
    "Ignoring the higher time frame closure requirement – a close beyond the POI invalidates the setup.",
    "Using this method when the sweep lacks clear aggression (no distinct wick formation on the higher time frame).",
    "Incorrectly identifying the HTF POI, leading to wrong reference area."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards are from ICT school; no conflict. The updated card provides more operational rules and precise definition, which were adopted.",
