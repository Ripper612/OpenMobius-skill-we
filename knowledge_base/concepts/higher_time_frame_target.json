{
  "card_id": "higher_time_frame_target",
  "type": "merged_concept",
  "canonical_term": "Higher Time Frame Target",
  "aliases": [
    "htf objective",
    "HTF Objective",
    "htf target",
    "HTF Target"
  ],
  "school": "ICT",
  "definition": "A significant price level drawn from a higher time frame, such as previous day highs/lows or HTF swing points acting as failure swings, that price has already reached. Once tagged, this level often marks the end of expansion and the start of a new phase of price, such as a reversal or change in state of delivery.",
  "identification_rules": [
    "Mark HTF liquidity levels (e.g., previous day highs/lows, HTF swing highs/lows acting as failure swings) on the chart prior to seeking entries.",
    "Identify when current price action has already run into or swept one of these marked HTF levels.",
    "Check if a continuation pattern is forming concurrently with the sweep of the HTF level — this signals a target has been hit, not a fresh expansion.",
    "Confirm by zooming out to the higher time frame and counting expansion candles; multiple consecutive expansion candles into a significant high/low indicate the HTF objective is reached.",
    "When price forms a continuation pattern at the HTF target, be alert for a new price phase or reversal."
  ],
  "trading_implication": "Avoid taking continuation entries after price has already reached a higher time frame target, as this is where a new phase of price (reversal or change in state of delivery) typically begins. FOMO entries chasing continuations at HTF targets frequently get stopped out. Instead, wait for the HTF wick to form fully and frame entries from the new structure once a fresh change in state of delivery confirms the next phase.",
  "common_mistakes": [
    "Entering a continuation setup out of FOMO after price has already swept the HTF target, getting stopped out as a new phase forms.",
    "Failing to zoom out to the higher time frame to check whether price has already reached a significant level before trading the lower time frame continuation.",
    "Trading a continuation that forms simultaneously with the taking out of an HTF high/low, which often sets up a bearish/bullish change in state of delivery instead.",
    "Failing to recognize the overlap of HTF targets with other structures (e.g., order blocks, fair value gaps), leading to misjudged support/resistance."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards are from ICT school; no conflict. The updated card provides more precise identification rules and trading implications, which were adopted. The original card's note about avoiding FOMO entries is preserved.",
