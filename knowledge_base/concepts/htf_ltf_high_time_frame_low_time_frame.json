{
  "card_id": "htf_ltf_high_time_frame_low_time_frame",
  "type": "merged_concept",
  "canonical_term": "HTF/LTF (High Time Frame / Low Time Frame)",
  "aliases": [
    "HTF/LTF Analysis",
    "HTF/LTF分析",
    "Multi-timeframe Analysis",
    "nested timeframe structure",
    "Nested Timeframe Structure",
    "time frame analysis",
    "Time Frame Analysis",
    "多时间框架分析",
    "时间框架下钻",
    "时间框架对比分析",
    "跨周期分析"
  ],
  "school": "ICT",
  "definition": "A layered analysis method using higher time frames (e.g., daily, 4H) to determine trend bias and key liquidity targets, and lower time frames (e.g., 15m, 5m, 1m) to pinpoint entry triggers such as market structure shifts or FVG fills, ensuring alignment with the higher time frame direction.",
  "identification_rules": [
    "Identify key liquidity targets (FVG, OB, swing highs/lows, PD Array) on higher time frames (daily, 4H, 1H) to set the overall bias.",
    "After confirming bias on HTF, drill down to LTF (15m, 5m, 1m, 15s) to find precise entry signals like MSS, displacement, FVG fill, or OTE retracement.",
    "Ensure LTF signal direction aligns with HTF trend; if HTF structure is intact, LTF counter-trend moves are retracements, not reversals.",
    "Look for aggressive price move out and back into a range on LTF, confirming no effective displacement on HTF.",
    "When HTF is in active expansion, LTF retracements should be shallow and fast, not deep.",
    "Compare stop and target levels across time frames to select the best risk-reward ratio for entry.",
    "Verify LTF candle wicks: small wicks support expansion, large wicks suggest reversal, consistent with HTF expectation.",
    "At HTF new candle open, check LTF price action for expected expansion or retracement behavior.",
    "LTF entries must be executed within Kill Zone time windows."
  ],
  "trading_implication": "HTF provides strategic direction and risk management (stop placement), while LTF offers tactical entry and tighter stops. By nesting LTF signals within HTF targets, traders achieve better risk-reward ratios and avoid premature exits. LTF monitoring confirms HTF setups remain valid, aiding timely adjustments.",
  "common_mistakes": [
    "Trading on LTF without confirming HTF bias, leading to counter-trend trades.",
    "Misinterpreting LTF structure break as trend reversal without checking HTF trend intact.",
    "Expecting deep LTF retracements when HTF is in active expansion (should be shallow).",
    "Entering without LTF confirmation (MSS, FVG fill, structure break), increasing false signals.",
    "Drilling down to LTF when HTF has no clear opportunity (no FVG, OB, or discount zone).",
    "Executing LTF signals that contradict HTF macro direction.",
    "Entering immediately after HTF POI is touched, without waiting for LTF aggressive return move.",
    "Ignoring HTF displacement, leading to entries at false breaks.",
    "Confusing LTF POI as HTF bias.",
    "Trading on LTF before HTF candle completes, lacking confirmation.",
    "Confusing HTF reversal day vs continuation day, misinterpreting LTF signals.",
    "Closing positions prematurely without verifying LTF price actually reached HTF target zone.",
    "Mistaking LTF consolidation for valid retracement, trading invalid setups.",
    "Trading structure breaks on HTF without displacement, risking inducement."
  ],
