{
  "card_id": "internal_range_liquidity_external_range_liquidity",
  "type": "merged_concept",
  "canonical_term": "Internal Range Liquidity / External Range Liquidity",
  "aliases": [
    "internal liquidity / external liquidity",
    "Internal Liquidity / External Liquidity",
    "IRL to ERL Model",
    "irl to erl model",
    "IRL/ERL",
    "irl/erl",
    "Universal Model"
  ],
  "school": "SMC",
  "definition": "A universal framework where internal range liquidity refers to fair value gaps inside a price range and external range liquidity refers to the swing highs/lows bounding the range. Price oscillates between the two: hitting IRL targets ERL, and reaching ERL retraces back into IRL.",
  "identification_rules": [
    "Mark external range liquidity at the swing high and swing low that bound the current range.",
    "Identify internal range liquidity as the fair value gap(s) located inside that range between the two external extremes.",
    "When price trades into an IRL (fair value gap), set the opposing external swing high/low as the next target.",
    "When price reaches or manipulates an ERL (range high/low), set the internal fair value gap as the first target for retracement.",
    "Confirm the reversal off IRL or ERL with a swing formation (candle 2 closure or candle 3 closure) before anticipating the move to the opposite side."
  ],
  "trading_implication": "IRL/ERL provides a universal directional roadmap: it tells the trader which side of the range price is drawn to next. After a reaction at IRL, traders position toward the opposing ERL; after ERL is swept, traders anticipate a retrace into the IRL fair value gap for continuation or, failing that, a rotation to the opposite ERL. Combined with candle 2 / candle 3 swing closures, it filters entries by requiring both a key level (IRL or ERL) and a confirmed swing formation before participating.",
  "common_mistakes": [
    "Anticipating a reversal at IRL or ERL without waiting for a swing formation (candle 2 or candle 3 closure) to confirm.",
    "Trying to participate in candle 3 before its close when candle 2 showed no signs of reversal off the key level.",
    "Trading a reversal candle with a large wick instead of an expansion candle with a small wick off the key level."
  ],
