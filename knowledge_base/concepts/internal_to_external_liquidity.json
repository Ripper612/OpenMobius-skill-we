{
  "card_id": "internal_to_external_liquidity",
  "type": "merged_concept",
  "canonical_term": "Internal to External Liquidity",
  "aliases": [
    "Internal Liquidity to External Liquidity",
    "internal liquidity to external liquidity",
    "internal-to-external price movement",
    "Internal-to-External Price Movement"
  ],
  "school": "ICT",
  "definition": "A price delivery pattern where price moves from internal liquidity (e.g., fair value gaps within a range) to external liquidity (swing highs/lows). After filling the internal gap, price expands to take out the external liquidity level, reflecting cyclical range expansion.",
  "identification_rules": [
    "Identify an unfilled fair value gap within the current price range as internal liquidity.",
    "Identify the nearest swing high or swing low outside the range that serves as external liquidity.",
    "Confirm a directional bias via a candle 2 closure or change in state of delivery on the higher time frame.",
    "Wait for price to retest the internal liquidity zone (fair value gap) before aiming for the external target.",
    "Use lower time frame (15m/1m) fractal models to find precise entries when an internal-to-external move is expected.",
    "Confirm breakout with an expansion candle showing increased momentum.",
    "Verify that price does not return inside the internal zone after breakout."
  ],
  "trading_implication": "Traders use internal-to-external liquidity to time entries after internal gaps are filled, targeting external swing points. It provides a structured framework for scalping with higher time frame context, anticipating expansion candles that travel from a filled FVG to a liquidity sweep at a key external level.",
  "common_mistakes": [
    "Entering too early before internal liquidity is fully respected, leading to stop-outs.",
    "Confusing a retracement into internal liquidity with a reversal, missing the continuation to external targets.",
    "Neglecting higher time frame bias, which can invalidate the direction of the internal-to-external move."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
