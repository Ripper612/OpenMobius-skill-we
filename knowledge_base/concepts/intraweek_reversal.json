{
  "card_id": "intraweek_reversal",
  "type": "merged_concept",
  "canonical_term": "Intraweek Reversal",
  "aliases": [
    "Mid-week Reversal Profile",
    "mid-week reversal profile"
  ],
  "school": "ICT",
  "definition": "A weekly profile where the high or low of the week does not form on Monday; instead Monday/Tuesday expand away from the intended weekly direction, a reversal swing point forms on Wednesday or Thursday, and the remaining days expand in the opposite direction.",
  "identification_rules": [
    "Confirm Monday (and possibly Tuesday) expands away from the intended weekly bias rather than forming the high/low of week.",
    "Look for a candle 2 closure or candle 3 closure on the weekly candle occurring mid-week (Wednesday, or Thursday if Wednesday also consolidates).",
    "Require an hourly change in the state of delivery inside the mid-week reversal candle before anticipating continuation.",
    "After the reversal swing point forms, expect the following days (Thursday/Friday, or Friday alone) to expand in the new direction."
  ],
  "trading_implication": "Used when the week does not produce a clean classic-expansion, midweek-reversal, or Thursday-counter profile. Traders wait for the weekly high/low to form mid-week, confirm with an hourly CISD inside the reversal candle, then trade swing points away from that level on the remaining days using the daily and hourly fractal model. Provides a framework for messier weeks where the reversal is delayed past Monday.",
  "common_mistakes": [
    "Trying to pattern-match the week to a template instead of applying the logic combined with daily and hourly fractal analysis.",
    "Entering before an hourly change in the state of delivery has occurred inside the reversal candle.",
    "Assuming the reversal must always be on Wednesday rather than allowing Thursday to be the reversal day if Wednesday consolidates."
  ],
