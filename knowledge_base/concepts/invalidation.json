{
  "card_id": "invalidation",
  "type": "merged_concept",
  "canonical_term": "Invalidation",
  "aliases": [
    "protected swing invalidation",
    "Protected Swing Invalidation"
  ],
  "school": "SMC",
  "definition": "The price level of a protected swing high or low that, if breached, negates the current directional expectation. Stops are placed beyond it, and a new invalidation forming on a lower time frame provides the entry reference for continuation trades with measurable risk-to-reward.",
  "identification_rules": [
    "Locate a swing high/low that has been confirmed by a closure through the series of opposing (up-close or down-close) candles that formed it.",
    "Confirm the swing was created at or after sweeping a prior high/low into a point of interest (e.g. fair value gap, order block).",
    "Mark that swing high/low as the invalidation level — price should not trade back through it if the bias remains valid.",
    "Wait for a new invalidation to form closer to the current price when the original invalidation is too far for acceptable risk-to-reward."
  ],
  "trading_implication": "Invalidation defines stop placement and structural bias. Traders sell with stops above a protected high (or buy with stops below a protected low) and target at least 2R, often extending to standard deviation projections or opposing failure swings. The focus is on anticipating new invalidations forming on lower time frames, which provide continuation entries close to risk, rather than trying to catch the initial reversal at the original swing.",
  "common_mistakes": [
    "Entering with the stop placed on a distant protected swing, producing poor risk-to-reward instead of waiting for a new invalidation closer to price.",
    "Trying to catch the initial reversal rather than entering on the continuation confirmed by a new protected swing.",
    "Treating an unconfirmed swing (no closure through the opposing candle series) as a valid invalidation."
  ],
