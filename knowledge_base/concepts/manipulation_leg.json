{
  "card_id": "manipulation_leg",
  "type": "merged_concept",
  "canonical_term": "Manipulation Leg",
  "aliases": [
    "扫荡腿",
    "操纵段",
    "操纵腿"
  ],
  "school": "ICT",
  "definition": "The swing that sweeps liquidity (often equal highs/lows) before a change in state of delivery, used as the anchor for standard deviation projections to estimate distribution targets. It is the complete price range from the extreme that creates a short-term high/low to that extreme itself, after which price reverses and forms a market structure shift.",
  "identification_rules": [
    "Identify a short-term high or low; price then displaces beyond that extreme.",
    "Confirm a reversal and market structure shift (Change in State of Delivery / Market Structure Shift) after the displacement.",
    "Mark the complete price range from the opposite extreme (start) to the extreme itself (end) as the Manipulation Leg.",
    "Use Fibonacci tool anchored from start to end of the Manipulation Leg.",
    "Assess the size of the Manipulation Leg to determine reasonable projection targets.",
    "Alternatively, identify a consolidation range, look for an aggressive breakout beyond the range, then a reversal back into the range, sweeping liquidity; measure the leg from extreme high to low."
  ],
  "trading_implication": "The Manipulation Leg is the anchor for Fibonacci standard deviation projections. Normal legs project to -2 to -2.5 standard deviations; large legs project only to -1; extreme cases to -4. Targets should align with PD array (FVG, OB, equal highs/lows) or liquidity zones. Multiple legs' projections increase reliability. The leg forms the wick of the daily candle, while subsequent distribution forms the body.",
  "common_mistakes": [
    "Confusing the Manipulation Leg with the entire trend; focus only on the swing before reversal.",
    "Mistaking the extreme point itself for the leg, rather than the complete move after displacement.",
    "Marking the leg before market structure shift is confirmed, leading to wrong anchor.",
    "Incorrectly anchoring Fibonacci tool, causing skewed projection levels.",
    "Projecting large legs to -2 or -2.5, setting unrealistic targets.",
    "Ignoring leg size when selecting projection levels.",
    "Relying solely on projections without PD array or liquidity confluence.",
    "Spending too much effort identifying accumulation range before recognizing the leg; focus on the aggressive move out and back in."
  ],
