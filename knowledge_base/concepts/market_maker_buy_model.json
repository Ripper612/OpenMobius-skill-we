{
  "card_id": "market_maker_buy_model",
  "type": "merged_concept",
  "canonical_term": "Market Maker Buy Model",
  "aliases": [
    "Buy model",
    "Buy Model",
    "buy model",
    "mmbm",
    "MMBM"
  ],
  "school": "ICT",
  "definition": "A bullish delivery model where price moves from external range liquidity (sweeping sellside) into internal range liquidity (a fair value gap), shifts state of delivery, then expands from internal back to external range liquidity higher, targeting prior swing highs.",
  "identification_rules": [
    "Identify external range liquidity (a prior swing high/low) and internal range liquidity (a fair value gap inside the range) on the bias time frame.",
    "Price must reach into internal range liquidity (the fair value gap) from external range liquidity and respect it.",
    "Confirm a change in state of delivery (close through the opposing candle series) above a relevant short-term high after the sweep.",
    "After the shift, the draw shifts to the upside external range liquidity (old swing high) as the target.",
    "On the lower time frame, enter on a retest of an order block or fair value gap with stop below the swept low, targeting the higher time frame external liquidity.",
    "Price previously swept external range liquidity (sellside) and then entered internal range liquidity (forming FVG or retracement area)."
  ],
  "trading_implication": "Used to frame bullish bias and entries across any time frame by tracking the internal-to-external liquidity cycle. Higher time frame provides directional narrative; lower time frames find precise entries (order block, FVG) after a change in state of delivery. Can nest: a lower time frame buy model can form within a higher time frame buy model.",
  "common_mistakes": [
    "Expecting a clean retracement before the expansion to external liquidity — price does not always retrace and may continue directly higher.",
    "Entering before a change in state of delivery confirms the shift from sell model to buy model.",
    "Ignoring the higher time frame internal/external liquidity context and trading the model in isolation on a low time frame."
  ],
  "related_concepts": [],
