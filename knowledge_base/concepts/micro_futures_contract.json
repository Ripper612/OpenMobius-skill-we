{
  "card_id": "micro_futures_contract",
  "type": "merged_concept",
  "canonical_term": "Micro Futures Contract",
  "aliases": [
    "micro",
    "Micro",
    "Micros"
  ],
  "school": "Risk Management",
  "definition": "A futures contract sized at one-tenth of a standard mini futures contract. Used to fine-tune position sizing when a full mini contract would exceed the desired fixed dollar risk per trade, providing greater flexibility in matching exact risk targets.",
  "identification_rules": [
    "A micro contract's value per point is 1/10th of the corresponding mini contract (e.g., MNQ vs NQ).",
    "To convert from mini contract sizing to micro contract sizing, multiply the calculated mini contract quantity by 10 (shift the decimal one place).",
    "Since fractional contracts cannot be traded, round the micro quantity down to the nearest whole number.",
    "Use micros when the calculated mini quantity is fractional (e.g., 2.5 NQ = 25 micros) and exact dollar risk is required."
  ],
  "trading_implication": "Micro futures allow traders to maintain consistent fixed-dollar or fixed-percentage risk per trade, which is essential for the win-rate/risk-reward profitability table to hold. When a calculated mini contract size results in a fraction (e.g., 2.817 NQ contracts to risk $1,000), the trader drops to micros (28 MNQ) to achieve the precise risk target. This is especially useful on smaller accounts or prop firm drawdown-based sizing where mini contracts would over-risk the position.",
  "common_mistakes": [
    "Using fixed mini contract sizes regardless of stop distance, producing inconsistent dollar risk across trades and breaking the win-rate/RR profitability math.",
    "Forgetting that you cannot trade a fractional mini contract and over-risking by rounding up instead of dropping to micros.",
    "Not rounding the micro quantity down, leading to slight over-risk on the trade."
  ],
