{
  "card_id": "new_york_continuation",
  "type": "merged_concept",
  "canonical_term": "New York Continuation",
  "aliases": [
    "NY Continuation",
    "ny continuation"
  ],
  "school": "ICT",
  "definition": "An expansion move during the New York session that continues the directional bias established by a London session reversal/low (or high) formation. Characterized by alternating large-range and small-range candles with shallow retracements rather than a manipulation of the prior session's swing point.",
  "identification_rules": [
    "Confirm a London session swing (low or high) formed with a protected swing via change in state of delivery (closure over the down-close candles for a low, under up-close candles for a high).",
    "Observe that price does NOT manipulate the London-formed high/low at the New York open — manipulation would signal a reversal, not continuation.",
    "Look for a sequence of large-range candles followed by small-range candles (consolidation or shallow retracement) and then another large range in the direction of bias.",
    "Retracements must be shallow and slow; deep or aggressive opposing moves invalidate continuation.",
    "Mark previous day high/low as the draw on liquidity to confirm continuation targets."
  ],
  "trading_implication": "Used to align New York session entries with the bias set in London. After a London reversal confirms a protected swing, traders anticipate continuation rather than a counter-move at NY open. Entries are taken on shallow retracements or small-range consolidations within the expansion, targeting previous day high/low or other external liquidity. Recognizing continuation signature (large range → small range → large range) prevents fading the trend during NY.",
  "common_mistakes": [
    "Expecting a manipulation of the London high/low at New York open (which would indicate reversal, not continuation).",
    "Treating a deep or aggressive opposing move as a retracement when it actually signals reversal or consolidation.",
    "Forcing a continuation trade when price action is messy (e.g., after two days of expansion already played out)."
  ],
