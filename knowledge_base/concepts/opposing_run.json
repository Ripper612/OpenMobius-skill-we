{
  "card_id": "opposing_run",
  "type": "merged_concept",
  "canonical_term": "Opposing Run",
  "aliases": [
    "Judas swing",
    "Judas Swing",
    "judas swing",
    "Opposing Candle",
    "opposing move",
    "Opposing Move",
    "Wick",
    "反向运动",
    "对抗运动"
  ],
  "school": "ICT",
  "definition": "A false move opposite to the anticipated directional bias that occurs at a key session open (midnight, 8:30, 9:30, 10:00, 14:00 EST) or after price retests a point of interest (FVG, order block, liquidity). The move sweeps liquidity or reaches into a POI, then reverses and closes back through the opposing candles, validating an order block and confirming trend continuation.",
  "identification_rules": [
    "Establish a directional bias from higher timeframe analysis before looking for the pattern.",
    "The pattern occurs after a key session open (midnight, 8:30, 9:30, 10:00, 14:00 EST) with a move opposite to the bias that sweeps a session high/low or previous day high/low.",
    "Alternatively, price must first retest a point of interest (FVG, order block, liquidity area, swept swing high/low) before forming the opposing run.",
    "At the POI, a candle forms with direction opposite to the current trend (e.g., bearish candle in an uptrend).",
    "The opposing run must close back through the series of opposing candles, validating an order block, and the swept level must not be retaken afterwards.",
    "Confirmation via SMT divergence between correlated assets at the swept level is recommended.",
    "After the false move, there should be failure of any bullish/bearish PD array on the manipulation side and displacement back in the intended direction.",
    "The opposing run can overlap with FVG or order block for multi-point confirmation.",
    "Exclude opposing runs that do not occur at key session opens or after retesting a POI."
  ],
  "trading_implication": "The Opposing Run marks a high-probability entry in the direction of daily bias after a false move at a session open or POI retest. Traders wait for a sweep of a session high/low or POI, confirm with SMT divergence and order block formation, then enter targeting opposing liquidity. Entry after closure back through opposing candles; stop beyond the swept level. Best used with higher timeframe context, Power of 3, and session timing; not a standalone signal.",
  "common_mistakes": [
    "Mistaking the opposing run for a reversal or entering without an established higher timeframe directional bias.",
    "Entering immediately on the sweep without waiting for structural confirmation (order block validation, displacement) or closure back through opposing candles.",
    "Looking for Opposing Runs at random levels instead of key session opens (midnight, 8:30, 9:30) and previous day highs/lows or POIs.",
    "Confusing Opposing Run with Order Block – the former requires closure back through candles for confirmation.",
    "Ignoring the depth of the opposing run: shallow wicks support expansion within the same candle; deep runs require waiting for the next candle.",
    "Not combining with CSD (Change in State of Delivery) for shallow opposing runs."
  ],
