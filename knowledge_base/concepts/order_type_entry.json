{
  "card_id": "order_type_entry",
  "type": "merged_concept",
  "canonical_term": "Order Type Entry",
  "aliases": [
    "OTE"
  ],
  "school": "ICT",
  "definition": "在ICT交易体系中，价格回撤至特定价格水平（如Fair Value Gap区域）时的低时间框架入场方式，通常结合K线反转形态（如2-2 Reversal、2-1-2 Reversal或Inside Bar）确认入场信号。",
  "identification_rules": [
    "在高时间框架（15分钟或5分钟）确认ICT核心结构：流动性扫荡（Liquidity Sweep）→ 结构突破（BOS）→ Fair Value Gap形成",
    "切换至低时间框架（1分钟、3分钟或5分钟），等待价格回撤至FVG区域",
    "在FVG区域内观察K线反转形态：2-2 Reversal（第二根K线低点低于第一根则做空触发）、2-1-2 Reversal或Inside Bar",
    "以触发K线的高点（做空时）作为止损位",
    "目标指向结构中的前期低点或流动性区域"
  ],
  "trading_implication": "OTE用于在ICT结构性做空/做多设置中寻找精确入场点，避免在价格逆向运动时盲目入场。建议优先在5分钟或3分钟图上操作，1分钟图虽可用但容易产生假信号。入场后以触发K线极值为止损，以前期结构低点/高点为目标，可在15分钟、5分钟、1分钟三个时间框架逐级细化入场精度。",
  "common_mistakes": [
    "在1分钟图上使用OTE容易被假信号欺骗（视频明确指出1分钟图'fake you out a lot'），建议使用5分钟或3分钟图",
    "未等待低时间框架K线反转形态确认即入场，缺乏明确触发信号"
  ],
