{
  "card_id": "ote_optimal_trade_entry",
  "type": "merged_concept",
  "canonical_term": "OTE (Optimal Trade Entry)",
  "aliases": [
    "Optimal Trade Entry",
    "ote of a range",
    "OTE of a range",
    "最优交易入场",
    "最优交易入场点",
    "最优入场点",
    "高概率入场区域"
  ],
  "school": "ICT",
  "definition": "A high-probability entry zone within the discount (for longs) or premium (for shorts) area, identified by applying Fibonacci retracement (0.5, 0.618, 0.625, 0.705, 0.786) from a complete displacement leg. The zone must overlap with PD arrays like FVG or Order Block, confirmed on higher timeframe structure, with entry triggered on lower timeframe.",
  "identification_rules": [
    "Identify a complete displacement or impulse leg, marking its start (low/high) and end (high/low).",
    "Apply Fibonacci retracement from leg start to end, focusing on levels 0.5, 0.618, 0.625, 0.705, 0.786.",
    "Determine the dealing range high/low; use 0.5 equilibrium as boundary: discount below (longs), premium above (shorts).",
    "OTE zone must overlap with FVG, Order Block, or other PD array elements for confluence.",
    "On higher timeframe (e.g., 4H, 1H), mark OTE zone; then switch to lower timeframe (15m, 5m, 1m) for entry trigger (displacement, FVG, candlestick reversal, or market structure shift).",
    "Confirm price has not closed within the zone (i.e., zone not mitigated) and OTE lies within multiple structural discount/premium areas.",
    "Verify risk-to-reward ratio from OTE stop to first target is favorable.",
    "On higher timeframe, confirm displacement, market structure shift (MSS), and imbalance to determine trend direction.",
    "Entry target should point to clear liquidity zones (swing highs/lows, FVG, equal highs/lows)."
  ],
  "trading_implication": "OTE bridges macro bias from higher timeframe to micro execution on lower timeframe. First confirm displacement range, premium/discount direction, and main targets on HTF. Then wait for price to retrace into OTE zone on LTF and trigger entry via FVG, OB, or displacement. Missed first OTE can be followed by secondary opportunities. OTE also serves as target or take-profit zone for counter-trend trades. Entry improves risk-reward ratio from ~1.6:1 to over 3:1 compared to equilibrium entry. After entry, trail stop to protected swing points on structure breaks.",
  "common_mistakes": [
    "Not calculating Fibonacci from a complete displacement leg, leading to inaccurate OTE zone.",
    "Not confirming displacement, MSS, and imbalance on higher timeframe before seeking OTE on lower timeframe.",
    "Taking long in premium zone or short in discount zone, opposite to OTE direction.",
    "Relying solely on Fibonacci levels without confluence from FVG, OB, or other PD arrays.",
    "Entering after price has closed within the zone (zone mitigated).",
    "Entering prematurely on LTF without a clear trigger signal (displacement, FVG, or structure break).",
    "Confusing OTE with equilibrium (0.5): 0.5 is the boundary, not the entry point itself.",
    "Missing secondary OTE opportunities after the primary entry is missed.",
    "Confusing OTE with FVG: OTE is a Fibonacci-based zone, FVG is a specific price gap.",
    "Treating too large a price range as a single OTE, reducing entry precision.",
    "Ignoring internal liquidity levels, leading to immediate stop-outs.",
    "Moving stop prematurely without confirmation of structure break.",
    "Failing to confirm that price has not broken through on higher timeframe, mistaking false breakout for real move."
  ],
