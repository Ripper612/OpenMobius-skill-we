{
  "card_id": "position_sizing",
  "type": "merged_concept",
  "canonical_term": "Position Sizing",
  "aliases": [
    "Fixed Dollar Risk",
    "Fixed Percentage Risk",
    "仓位管理",
    "仓位规模",
    "合约数量计算"
  ],
  "school": "Risk Management",
  "definition": "The process of adjusting contract or lot size per trade to maintain a fixed dollar or percentage risk, calculated as defined risk divided by instrument value per point divided by stop size in points. This ensures consistent risk per trade, making win rate and risk-to-reward ratios mathematically valid.",
  "identification_rules": [
    "Define a fixed dollar or percentage risk amount per trade (e.g., $1,000 or 1% of account) before sizing.",
    "Calculate contracts as: defined risk ÷ instrument value per point ÷ stop size in points.",
    "Multiply contract result by 10 to convert from minis to micros when fractional minis are needed.",
    "Round down to the nearest whole micro/contract when the calculation yields a fraction.",
    "For prop firm accounts, base the risk percentage on the drawdown limit, not the nominal account size.",
    "Fixed contract method: using same number of contracts per trade, but risk amount varies with stop size, leading to inconsistent risk."
  ],
  "trading_implication": "Consistent position sizing is prerequisite for win rate and risk-to-reward to translate into profitability. Fixed risk method (dollar or percentage) ensures each trade risks the same amount, making cumulative returns match theoretical expectancy. Micros are preferred for granularity. On prop firm accounts, size against drawdown (e.g., 7-10% of $1,500 drawdown on a 25K account) to absorb 10-15 consecutive losses.",
  "common_mistakes": [
    "Using fixed contract size instead of fixed dollar risk, producing inconsistent R values across different stop sizes and breaking win rate/RR profitability math.",
    "Risking different dollar amounts per trade, converting a winning system into break-even or worse.",
    "Sizing prop firm accounts against nominal balance (e.g., 1% of $25K) instead of drawdown limit, leading to blow-up in 6-7 losses.",
    "Rounding up fractional contracts instead of down, causing actual risk to exceed preset limit."
  ],
