{
  "card_id": "precision_swing_point",
  "type": "merged_concept",
  "canonical_term": "Precision Swing Point",
  "aliases": [
    "PSP",
    "psp"
  ],
  "school": "ICT",
  "definition": "A signal where two correlated assets close in opposite directions on the same candle—one bullish, the other bearish—indicating a potential reversal. Credited to Trader Daye, used as a first- or second-stage confirmation within two-stage SMT sequences.",
  "identification_rules": [
    "Identify two correlated markets (e.g., CL and HO, GC and Gold/GBP).",
    "Observe the same candle across both assets on the same time frame: one closes bullish, the other closes bearish.",
    "Confirm that the opposite closes occur on the same candle or adjacent candles.",
    "For a two-stage PSP between candle 1 and candle 2, the PSP must form after a first-stage SMT to confirm the reversal.",
    "For a two-stage PSP between candle 2 and candle 3, the PSP forms first and is confirmed by an SMT between candle 2 and candle 3.",
    "For a continuation PSP, one asset retraces back into the range and closes opposite the other, then the second asset runs out the PSP candle's high/low without forming a swing point on the other."
  ],
  "trading_implication": "PSP confirms reversals at key levels (FVG, order blocks, range high/low) and pairs with SMT sequences for entries. A two-stage SMT combining a key-level SMT with a PSP, then a cracking correlation swing-point SMT, is the highest-probability reversal signature. Continuation PSPs are used during expansion toward targets. Traders execute the following candle in the direction opposite the swept liquidity.",
  "common_mistakes": [
    "Misinterpreting equal highs in correlated markets as PSP reversal signals, ignoring the narrative of both markets expanding away from the original reversal point.",
    "Failing to distinguish between reversal PSP (confirms reversal) and continuation PSP (forms during expansion, does not create a swing point).",
    "Over-relying on PSP alone without key level context; should combine with range framework, FVG, or order blocks."
  ],
  "related_concepts": [
    {
      "term": "SMT"
    },
    {
      "term": "FVG"
    },
    {
      "term": "Order Block"
    },
    {
      "term": "Liquidity Sweep"
    }
  ],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "School conflict: one card says SMC, the other ICT. Picked ICT by majority (2 ICT vs 1 SMC). Definition merged: kept the more precise English version from the updated card, which includes credit to Trader Daye and two-stage SMT sequences. Identification rules unioned, preserving continuation PSP nuance from the updated card. Common mistakes from the first card retained; second card had none explicitly stated.",
  "warnings": [
    "school_conflict: ['ICT', 'SMC']"
  ],
