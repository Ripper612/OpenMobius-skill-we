{
  "card_id": "premium_and_discount",
  "type": "merged_concept",
  "canonical_term": "Premium and Discount",
  "aliases": [
    "0.5 Fib Range Division",
    "0.5 fib range division",
    "Discount Zone",
    "p/d array",
