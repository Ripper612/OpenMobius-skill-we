{
  "card_id": "premium_discount_array",
  "type": "merged_concept",
  "canonical_term": "Premium/Discount Array",
  "aliases": [
    "PD array",
    "PDA",
    "pd数组",
    "PD数组",
    "Premium/Discount",
    "Price Delivery Array",
    "价格结构工具集合",
    "价格驱动阵列",
    "高时间框架价格结构阵列"
  ],
  "school": "ICT",
  "definition": "A collection of structural obstacles (FVG, Order Block, Breaker Block, BPR, Inversion, etc.) arranged in an array within premium (above 50% equilibrium) or discount (below 50% equilibrium) zones. The 0.5 Fibonacci level divides the price range into premium (favoring shorts) and discount (favoring longs). Traders select one concept from the array as the primary signal.",
  "identification_rules": [
    "Identify the price range from a swing high to swing low and calculate its 50% equilibrium level using Fibonacci retracement.",
    "Price above the 50% equilibrium is in premium; price below it is in discount.",
    "Within the premium or discount zone, mark all structural obstacles in price order: FVG, Order Block, Breaker Block, BPR, Inversion, prior swing highs/lows, etc., forming an ordered array.",
    "Only include key levels that have been respected by prior price action and have structural significance, not every price level.",
    "Treat these structures as a collective array zone, not as individual support/resistance levels.",
    "Based on personal model, select one concept (e.g., OB, FVG, Breaker Block) as the primary trade signal and define its corresponding invalidation point.",
    "When price breaks through one element in the array, continue to monitor the next array element as a target.",
    "When looking for specific entry setups (e.g., displacement, breaker block) on lower timeframes, align them with key positions in the higher timeframe PD Array."
  ],
  "trading_implication": "PD Array bridges higher timeframe macro structure and lower timeframe micro entries. After confirming direction on higher timeframe, look for long setups in discount and short setups in premium. On lower timeframe, find specific entry models like displacement, OB, or FVG within the array. If PD Array is broken, it signals trend continuation; if respected, it may lead to reversal. Stop loss and invalidation are set based on the selected tool set. Combined with PD arrays, it increases entry precision and risk/reward by targeting the opposite side of the range.",
  "common_mistakes": [
    "Treating a single structure (e.g., FVG or OB) in isolation, ignoring the collective support/resistance of the entire array.",
    "Mistaking a single FVG or OB for the PD Array, overlooking the key feature of multiple overlapping structures.",
    "Failing to distinguish whether price has actually entered the discount or premium zone, leading to wrong trade direction.",
    "Entering blindly just because price reaches the PD Array without confirmation from lower timeframe setups.",
    "Marking PD Array on lower timeframe without first confirming the main trend direction on higher timeframe, causing incorrect target setting.",
    "Including all price levels in the array instead of only key levels that have been respected and have structural significance.",
    "Ignoring low-resistance liquidity (uncleared swing points), allowing price to easily pass through some PD Array elements without reaction.",
    "Looking for inducement setups outside the PD Array, reducing trade probability.",
    "Entering too early before price actually reaches the zone and shows a reaction.",
    "Trying to use all PD Array concepts simultaneously, leading to chart clutter and signal confusion.",
    "Not clearly defining the PD Array tool set used, resulting in vague invalidation points.",
    "Confusing different PD Array frameworks, applying invalidation rules from one framework to another.",
    "Missing multiple entry opportunities within the PD Array and giving up on the zone after one missed trade.",
    "Buying in premium in a bullish trend without additional confirmation, risking buying at overvalued levels.",
    "Selling in discount in a bearish trend without confirmation, risking selling at undervalued levels.",
    "Ignoring higher timeframe bias: being bullish in discount while HTF is bearish."
  ],
