{
  "card_id": "previous_day_high_low",
  "type": "merged_concept",
  "canonical_term": "Previous Day High / Low",
  "aliases": [
    "PDH",
    "PDL"
  ],
  "school": "ICT",
  "definition": "The high and low of the prior trading day, used as draw-on-liquidity targets or reversal points. Unless price is consolidating, it tends to reach for one or both of these levels during the next day's session. In trending contexts, price often draws to these levels; a sweep and rejection can signal a reversal.",
  "identification_rules": [
    "On the daily chart, locate the high and low of the previous complete trading day's candlestick.",
    "Extend these levels horizontally into the current trading day as horizontal reference lines.",
    "Optionally, look back up to 3 trading days to mark multiple previous day highs/lows for confluence zones.",
    "Assess whether price is consolidating or directional; if directional, anticipate a move toward the previous day's high or low.",
    "In an uptrend, price repeatedly touches or breaks the previous day high; in a downtrend, it repeatedly touches or breaks the previous day low.",
    "When price fails to break the previous day high, it indicates a bearish bias; failure to break the previous day low indicates a bullish bias.",
    "Observe whether price consolidates within the previous day high/low range or breaks and closes outside the range (a mere touch is not enough to confirm direction).",
    "These horizontal levels remain valid as reference levels on lower timeframes (e.g., 1-hour, 5-minute)."
  ],
  "trading_implication": "Previous Day High/Low serves as a daily-level liquidity target for framing intraday bias and finding entries on lower timeframes. Unless price is consolidating, expect price to reach one of these levels. A break and close outside the range suggests trend continuation; combined with displacement, failed breaks, and session liquidity, it can frame reversal or continuation bias and provide stop or target references.",
  "common_mistakes": [
    "Assuming a trade opportunity exists every day even when no valid entry is present.",
    "Ignoring displacement – judging bias solely on previous day high/low without considering whether price successfully breaks.",
    "Not distinguishing between a touch and a close outside the range – a mere touch is insufficient to confirm direction.",
    "Assuming price will necessarily reach the previous day high/low when not in consolidation, ignoring the consolidation exception.",
    "Confusing Previous Day High/Low with the current day's high/low or opening price, leading to wrong reference levels.",
    "Confusing Previous Day High/Low with session highs/lows, leading to incorrect liquidity targets.",
    "Failing to mark Previous Day High/Low across multiple timeframes, losing reference on lower timeframes.",
    "Over-relying on Previous Day High/Low without other structures – should confirm with FVG, Order Block, Swing Points, etc.",
    "Expecting price to reach the previous day high/low during consolidation phases when no directional expansion is signaled.",
    "Treating every touch as an automatic reversal without confirmation from displacement or market structure shift."
  ],
