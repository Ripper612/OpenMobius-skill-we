{
  "card_id": "previous_day_high_previous_day_low",
  "type": "merged_concept",
  "canonical_term": "Previous Day High / Previous Day Low",
  "aliases": [
    "PDH",
    "PDL",
    "Previous Day High",
    "Previous Day Low"
  ],
  "school": "ICT",
  "definition": "The high and low prices of the immediately preceding trading day, marked as horizontal levels on the current chart. They serve as intraday liquidity targets (draw on liquidity) where price is expected to reach, and as potential reversal points.",
  "identification_rules": [
    "On the daily chart, note the highest and lowest price of the most recent closed daily candle; these are the previous day high and previous day low.",
    "Transfer these levels as horizontal lines to intraday time frames (e.g., 5-minute, 1-hour) for the current trading session.",
    "On daily or intraday charts, find the highest price of the previous complete trading day and draw a horizontal line labeled Previous Day High.",
    "Find the lowest price of the same previous complete trading day and draw a horizontal line labeled Previous Day Low.",
    "Extend both horizontal lines into the current trading day as reference levels for price action."
  ],
  "trading_implication": "These levels act as key liquidity pools. Price often gravitates toward them. A sweep and rejection (with displacement or fair value gap) can frame a reversal; a clean break through with displacement signals continuation. They are commonly used as profit targets. In S&P 500 futures, when intraday session highs/lows are swept, price may extend to previous day high as a liquidity target.",
