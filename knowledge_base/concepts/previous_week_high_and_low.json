{
  "card_id": "previous_week_high_and_low",
  "type": "merged_concept",
  "canonical_term": "Previous Week High and Low",
  "aliases": [
    "PWH",
    "PWL",
    "上一周高点和低点",
    "周高低点"
  ],
  "school": "ICT",
  "definition": "The high and low of the prior trading week, serving as key liquidity levels that attract price for retests or reversals. A sweep with a close back inside the range suggests reversal; a decisive close beyond confirms continuation.",
  "identification_rules": [
    "Mark the previous week's high and low on a daily or weekly chart, extending the lines into the current week.",
    "Monitor price as it approaches these levels during the current weekly session.",
    "A sweep (wick beyond the level) that fails to displace — closing back inside the range — indicates a potential reversal.",
    "A close above the previous week's high or below the low with displacement confirms continuation in that direction.",
    "If price fails to reach either level, the week may remain range-bound between them."
  ],
  "trading_implication": "These levels frame draw-on-liquidity bias or anticipate reversals. A reversal at one extreme targets the opposite extreme; a continuation breakout sets directional bias for the week. They are part of top-down analysis for daily/weekly trade planning.",
  "common_mistakes": [
    "Assuming every touch triggers an immediate reversal without waiting for a close-back confirmation.",
    "Failing to observe displacement — wicks through without closing beyond still indicate a potential reversal, not continuation.",
    "Applying the concept rigidly during holiday-shortened weeks or low-volume periods where ranges naturally contract."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards are from ICT school; no conflict. The updated card provided more precise identification rules and trading implications, which were adopted.",
