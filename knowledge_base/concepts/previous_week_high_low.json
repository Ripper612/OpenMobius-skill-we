{
  "card_id": "previous_week_high_low",
  "type": "merged_concept",
  "canonical_term": "Previous Week High/Low",
  "aliases": [
    "Prior Week High/Low",
    "prior week high/low",
    "PWH",
    "PWL",
    "weekly high/low",
    "Weekly High/Low"
  ],
  "school": "ICT",
  "definition": "The high and low prices of the prior trading week, used as key liquidity levels where price often draws to or reverses unless consolidating. They frame potential draw-on-liquidity targets and reversal zones on higher time frames.",
  "identification_rules": [
    "Mark the high and low of the previous weekly candle on the chart.",
    "Extend these levels horizontally into the current week as reference lines.",
    "Unless the weekly candle is consolidating, anticipate price to reach toward one or both of these levels.",
    "A sweep and close beyond the level signals continuation; failure to displace and a close back inside indicates a potential reversal.",
    "On a daily chart, locate the peak and trough formed during the prior week’s trading sessions."
  ],
  "trading_implication": "Previous week high/low serves as a draw-on-liquidity target and reversal zone. When price is not consolidating, it is likely to reach for these levels. A close beyond confirms trend continuation; failure to displace warns of a reversal at that level. Always mark them to guide bias and entry decisions.",
  "common_mistakes": [
    "Ignoring consolidation contexts where price may not reach the previous week high/low.",
    "Treating every touch of the level as an automatic reversal without waiting for displacement confirmation.",
    "Entering too early before a close beyond the level, risking fakeouts.",
    "Not marking levels on multiple time frames, leading to neglect of higher timeframe liquidity structure."
  ],
