{
  "card_id": "profit_taking_strategy",
  "type": "merged_concept",
  "canonical_term": "Profit Taking Strategy",
  "aliases": [
    "止盈策略",
    "获利了结策略"
  ],
  "school": "Risk Management",
  "definition": "在价格到达-2至-2.5流动性点位时提前获利平仓，而非持有至最终目标，以规避价格反向运行导致已获利润损失的风险管理方法。",
  "identification_rules": [
    "识别标准差投影的-2至-2.5流动性水平位置",
    "确认该水平与失败摆动高/低点或其他汇聚信号重合",
    "观察价格在该水平是否形成整理或反转迹象",
    "判断该点位是否为范围内的内部流动性点（相对于最终目标）"
  ],
  "trading_implication": "在确认流动性汇聚的-2至-2.5水平获利，避免贪心持仓至最终目标而遭遇价格反向运行。该策略适用于价格可能进入整理或反转的场景，通过提前锁定大部分收益来优化风险回报比，特别是当最终目标与中间流动性点距离较远时。",
  "common_mistakes": [
    "贪心持仓至最终目标而非在-2至-2.5流动性点获利，导致价格反向时损失已获利润",
    "未能识别-2至-2.5水平与失败摆动或其他汇聚信号的对齐，盲目在该点位获利"
  ],
