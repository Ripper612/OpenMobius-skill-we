{
  "card_id": "projection",
  "type": "merged_concept",
  "canonical_term": "Projection",
  "aliases": [
    "London Manipulation Projection",
    "london manipulation projection",
    "manipulation leg projection",
    "Manipulation Leg Projection",
    "price projection",
    "Price Projection",
    "Standard Deviation Projection"
  ],
  "school": "ICT",
  "definition": "A technique that measures the price height of a manipulation leg (from high to low or low to high) and projects that height from the leg's endpoint or breakout point along the expected direction at multiples (e.g., 2x, 2.5x, 4x, 4.5x) to generate target levels, often corresponding to -2, -2.5, -4, -4.5 standard deviation lines. Used to set profit targets in distribution phases.",
  "identification_rules": [
    "Identify a manipulation leg: a price move that sweeps old high/low (liquidity sweep) then reverses, defined by its start and end extreme points.",
    "In a breaker block structure, the manipulation leg is the move from the high to the lower low in a low-high-lower low structure; projection starts from the breakout high.",
    "Measure the vertical distance from the start to the end of the manipulation leg; this is the projection base length.",
    "Project that base length from the leg's endpoint (or breakout point) in the expected direction, marking levels at 2x, 2.5x, 4x, 4.5x (corresponding to -2, -2.5, -4, -4.5 standard deviation lines).",
    "Focus on the -2 to -2.5 zone as primary target, -4 to -4.5 as extended target.",
    "Check if projected levels align with existing PD Array (equal highs/lows, order blocks, FVG, old highs/lows); alignment increases confidence.",
    "Use Fibonacci projection tool from leg start to end to read standard deviation levels.",
    "Optionally refine targets using standard deviation multiples (e.g., -2 standard deviation)."
  ],
  "trading_implication": "After manipulation phase confirmation (e.g., CISD, AMD leg completion, London liquidity sweep), use -2 to -2.5 standard deviation zone as primary take-profit, -4 to -4.5 as extended target. Higher confidence when projection aligns with PD Array or external liquidity. If near-term target yields less than 2R, use projection target instead. Combine with OTE entry for 3R+ targets.",
  "common_mistakes": [
    "Incorrectly identifying the manipulation leg (must be the move that sweeps liquidity, not any arbitrary swing).",
    "Projecting in the wrong direction (bullish projection up, bearish down).",
    "Using projection targets without waiting for manipulation confirmation (e.g., CISD).",
    "Ignoring alignment with PD Array or liquidity levels; using projection numbers alone.",
    "Over-relying on projection targets while neglecting quick 2R opportunities.",
    "Failing to combine higher timeframe projections with current timeframe for multi-timeframe confirmation."
  ],
