{
  "card_id": "propulsion_block",
  "type": "merged_concept",
  "canonical_term": "Propulsion Block",
  "aliases": [
    "continuation order block",
    "ob built off an ob",
    "OB built off an OB",
    "OB on OB",
    "ob on ob",
