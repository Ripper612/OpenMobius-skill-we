{
  "card_id": "range_consolidation",
  "type": "merged_concept",
  "canonical_term": "Range Consolidation",
  "aliases": [
    "Consolidation range",
    "Range-bound"
  ],
  "school": "Price Action",
  "definition": "价格在明确的高点（Range High）和低点（Range Low）之间反复波动、缺乏方向性的横盘整理形态。K线绿黑相间、波幅较小，价格多次触及边界但未能有效突破。突破任意一侧边界时整理结束，产生方向性交易机会。",
  "identification_rules": [
    "在图表上标记出清晰的范围高点（Range High / Consolidation High）和范围低点（Range Low / Consolidation Low）",
    "观察价格在两个边界之间形成多根K线，绿黑相间波动，缺乏强势方向性突破",
    "确认价格多次触及范围边界但未能持续突破，而是反复回测",
    "范围内K线通常较小，显示市场缺乏方向性动能",
    "在低时间框架（如1小时、30分钟）上表现更明显和频繁",
    "当价格收盘突破范围高点或低点时，标记为breakout信号，整理阶段结束"
  ],
  "trading_implication": "Range Consolidation常出现于扩张（Expansion）行情之后，用于识别市场整理阶段。交易者可在范围内寻找支撑/阻力反弹机会，或等待价格突破边界以确认趋势方向。范围内扫除低点后形成反转信号时，可结合高时间框架偏向进行低时间框架反转交易。需警惕范围内的虚假突破（Inducement）。结合前期摆动点（Swing Points）可增强判断可靠性。",
  "common_mistakes": [
    "在整理期间频繁交易，而非等待突破确认——整理阶段噪音较多，失败率高",
    "未等待价格收盘确认突破，在触及范围边界时过早入场",
    "将范围高点的突破误认为Change in State of Delivery，忽视需要一系列K线确认的要求",
    "过早进场，未等待shallow retracement和protected swing形成后的continuation确认",
    "假设范围必然会被突破，忽视价格可能继续在范围内波动的可能性",
    "混淆大consolidation与内部小consolidation，导致交易信号层级混乱",
    "混淆范围整理与真正的趋势反转，导致交易方向判断错误"
  ],
