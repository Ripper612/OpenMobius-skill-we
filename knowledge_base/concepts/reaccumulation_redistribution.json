{
  "card_id": "reaccumulation_redistribution",
  "type": "merged_concept",
  "canonical_term": "Reaccumulation / Redistribution",
  "aliases": [
    "Re-accumulation",
    "re-accumulation",
    "re-distribution",
    "Re-distribution"
  ],
  "school": "ICT",
  "definition": "Reaccumulation is consolidation in an uptrend where old bearish fair value gaps (SIBI) that failed as resistance become support for trend continuation. Redistribution is consolidation in a downtrend where old bullish fair value gaps (BISI) that failed as support become resistance for trend continuation.",
  "identification_rules": [
    "Confirm a clear trend (higher highs/lows for reaccumulation, lower highs/lows for redistribution).",
    "Identify an old opposing fair value gap from the opposite side of the market maker curve (SIBI for reaccumulation, BISI for redistribution).",
    "Price must have closed through the fair value gap, invalidating it (closed above for reaccumulation, below for redistribution).",
    "Wait for a retracement back to the invalidated fair value gap, where it now acts as support (reaccumulation) or resistance (redistribution).",
    "Look for price to respect the consequent encroachment or full gap before entering in the trend direction."
  ],
  "trading_implication": "These are trend-continuation setups. In an uptrend, price retracing to an old SIBI offers a buy entry with a stop below the gap. In a downtrend, price retracing to an old BISI offers a sell entry with a stop above the gap. Targets are the next liquidity level (swing highs/lows). They allow entries in the direction of the higher-timeframe bias after a retracement.",
  "common_mistakes": [
    "Treating unmitigated (fresh) fair value gaps as old gaps before price has closed through them.",
    "Entering on the first touch without confirmation of a retracement and respect of the level.",
    "Using them as reversal signals instead of trend-continuation entries."
  ],
