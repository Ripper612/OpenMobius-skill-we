{
  "card_id": "relative_strength",
  "type": "merged_concept",
  "canonical_term": "Relative Strength",
  "aliases": [
    "Relative Strength / Weakness",
    "relative strength / weakness",
    "relative weakness",
    "Relative Weakness"
  ],
  "school": "SMC",
  "definition": "Comparison of two correlated assets to determine which is stronger or weaker. It informs trade entry when an SMT divergence occurs: trade the weaker asset for shorts and stronger for longs, considering higher timeframe bias and which asset swept liquidity for safer stop placement.",
  "identification_rules": [
    "Compare matching swing points on two correlated assets at the same time: if one makes a higher high/low while the other fails, the failing asset shows relative weakness.",
    "For inversely correlated pairs (e.g., EUR/USD vs DXY), flip the structure — a higher high on one should pair with a lower low on the other; deviation signals divergence.",
    "Identify which asset swept liquidity (took out the prior high/low) and which did not — the sweeper has High Resistance Liquidity above/below it.",
    "Use higher timeframe setup to determine which asset is structurally stronger/weaker.",
    "Analyze a cross pair trend (e.g., EURGBP): a bullish trend confirms first currency stronger, second weaker; bearish confirms opposite.",
    "Compare daily candle closures of two assets against a common base; if one closes bearish and the other doesn't, it validates relative weakness.",
    "Confirm relative strength bias with lower timeframe Change in State of Delivery (CISD) or protected swing."
  ],
  "trading_implication": "Relative strength guides trade selection during SMT divergences, aligning with higher timeframe bias. For bullish dollar bias, short the weaker currency; for bearish, long the stronger. Similarly, in correlated assets, trade the weaker for shorts and stronger for longs. Prefer the asset that swept liquidity during high-volatility events for safer stop placement. This avoids missed expansions and being on the wrong side.",
  "common_mistakes": [
    "Ignoring relative strength and trading the wrong asset, leading to missed expansions or being caught offside despite correct bias.",
    "Treating the choice between diverging assets as mechanical, without considering higher timeframe setup and volatility context.",
    "Ignoring which asset swept liquidity when setting stops during high-volatility events, leading to stops at lower-resistance levels.",
    "Assuming correlated assets move identically without assessing their relative performance via cross pair or similar."
  ],
