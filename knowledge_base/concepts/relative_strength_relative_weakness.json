{
  "card_id": "relative_strength_relative_weakness",
  "type": "merged_concept",
  "canonical_term": "Relative Strength / Relative Weakness",
  "aliases": [
    "Currency Pairing",
    "Relative Strength Analysis"
  ],
  "school": "Order Flow",
  "definition": "A framework using fraction math to compare two currencies' individual strength, where pairing the strongest currency (numerator) with the weakest currency (denominator) produces the most expansive trend, while pairing currencies of equal strength produces consolidation.",
  "identification_rules": [
    "Assign each currency a state: strong bullish, bullish, consolidating, bearish, or strong bearish based on its individual trend.",
    "Treat the forex pair as a fraction: base currency is the numerator, quote currency is the denominator.",
    "If numerator is raised (bullish) and denominator is lowered (bearish), the pair has a very strong bullish trend.",
    "If numerator is lowered (bearish) and denominator is raised (bullish), the pair has a very strong bearish trend.",
    "If both numerator and denominator move the same direction (both bullish or both bearish), the pair will consolidate and should be avoided.",
    "If one side is trending and the other is consolidating, expect a trend but not the strongest expansion.",
    "When DXY is trending bullish, pair it with the weakest currency; when DXY is trending bearish, pair it with the strongest currency.",
    "When DXY is consolidating, ignore dollar pairs and pair the strongest non-dollar currency with the weakest non-dollar currency."
  ],
  "trading_implication": "Use relative strength to select the optimal forex pair for the day rather than trading any pair arbitrarily. Identify the strongest and weakest currencies across the currency board, then trade the pair that combines them to maximize expansion and trend quality. Avoid pairs where both currencies move in the same direction (consolidation risk). When DXY is the dominant trending instrument, anchor pair selection around it; when DXY consolidates, shift to cross pairs combining extreme strong/weak non-dollar currencies.",
  "common_mistakes": [
    "Pairing two strong currencies or two weak currencies together, resulting in consolidation instead of a trend.",
    "Pairing with the dollar when DXY is consolidating instead of switching to cross pairs.",
    "Pairing a trending currency with another trending currency moving in the same direction, neutralizing the move.",
    "Settling for a consolidation pairing when a stronger weak/strong combination is available."
  ],
