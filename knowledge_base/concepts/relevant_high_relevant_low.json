{
  "card_id": "relevant_high_relevant_low",
  "type": "merged_concept",
  "canonical_term": "Relevant High / Relevant Low",
  "aliases": [
    "Relevant Highs and Lows",
    "relevant swing high/low",
    "Relevant Swings",
    "significant price level"
  ],
  "school": "ICT",
  "definition": "A price level with market structure significance, typically a prior day/week high/low or swing high/low. Price reversals should form at these levels, not arbitrary highs/lows. The swing point must have sufficient separation from adjacent swings to be considered relevant.",
  "identification_rules": [
    "Identify prior day or week highs and lows as relevant levels.",
    "Identify swing highs and swing lows on the chart with valid separation (sufficient price distance from adjacent same-direction swings).",
    "Avoid arbitrary highs/lows; ensure the level has structural significance.",
    "When price breaks a relevant high/low and forms an 'expansion met with expansion' structure, that level is a valid reversal point.",
    "A relevant high/low should explain subsequent price reversal behavior without leaving ignored failed swings.",
    "Use a lookback period of three higher-timeframe candles (including current) to determine relevance; swings beyond this period are no longer relevant.",
    "When price enters a relevant swing point, observe for reversal, retracement, or breakout to assess validity.",
    "A relevant swing point should produce a clear price reaction, not be easily breached."
  ],
  "trading_implication": "Relevant highs/lows are key reference points for expected reversals. Traders should watch for reversal structures (e.g., expansion met with expansion) on lower timeframes when price touches these levels. Entry can be confirmed by fractal models (e.g., candle 2 or 3 close). Use relevant swings for stop placement; avoid positions at failed swings. If price reverses at a non-relevant level, the reversal may fail.",
  "common_mistakes": [
    "Selecting arbitrary highs/lows for reversal trades, leading to price breaking through rather than reversing.",
    "Ignoring obvious relevant levels like prior day/week highs/lows in favor of unclear swings.",
    "Anticipating reversals before price reaches a relevant high/low.",
    "Failing to check if a relevant high/low leaves a failed swing; if so, the level is not relevant.",
    "Mistaking failed swings (tightly clustered highs/lows) for relevant swings.",
    "Neglecting valid separation; attempting reversals at adjacent swings with insufficient distance.",
    "Considering old swings beyond the three-candle lookback period as still relevant.",
    "Entering prematurely before price action confirmation at the relevant level."
  ],
