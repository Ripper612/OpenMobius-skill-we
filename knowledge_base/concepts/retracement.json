{
  "card_id": "retracement",
  "type": "merged_concept",
  "canonical_term": "Retracement",
  "aliases": [
    "V-shaped recovery",
    "回撤",
    "回测",
    "回调",
    "短期回调",
    "缓慢回撤"
  ],
  "school": "Price Action",
  "definition": "价格在主趋势扩张后的缓慢、浅层反向回调，不突破前期关键摆动高/低点，不改变整体趋势方向。通常进入公允价值缺口（FVG）或其他关键水平，形成失败摆动后反转，进入新一轮扩张，构成扩张-回撤-扩张循环中的中间阶段。",
  "identification_rules": [
    "发生在扩张（Expansion）之后，价格反向移动但幅度浅、速度慢，K线表现为低波动性运动",
    "回撤不突破前期扩张的起点，不创出新的反向摆动高点或低点",
    "回撤过程中在高点或低点形成失败摆动（Failure Swings）",
    "回撤通常进入公允价值缺口（FVG）、订单块（Order Block）或其他关键支撑/阻力水平（PDA区域）",
    "回撤完成后形成受保护摆动（Protected Swing），随后价格反转进入新的扩张",
    "可通过日线收盘位置确认：收盘回到前期价格区间内部（而非突破下方）倾向于回撤而非反转",
    "回撤后应出现V形恢复或新的看涨/看跌K线形态，收盘快速穿过前期反向K线收盘价",
    "多时间框架验证：低时间框架的回撤方向应与高时间框架的扩张偏差（Bias）一致"
  ],
  "trading_implication": "回撤是趋势延续的关键信号，为交易者提供低风险入场机会。应等待回撤完成并确认新扩张信号（如受保护摆动形成、V形恢复、K线收盘穿越关键位）后再入场，以受保护摆动低/高点作为止损，目标指向前期高/低点。回撤的浅度和缓慢性质表明市场强度；若回撤过深或突破前期结构，则可能预示反转。可结合多时间框架提高入场精度。",
  "common_mistakes": [
    "将回撤与反转混淆：若价格突破前期关键摆动高/低点或形成新的反向结构，则为反转而非回撤",
    "将快速、大幅度的反向移动误认为回撤，实际上这是反转（Reversal）",
    "将缓慢浅层的回撤误判为盘整（Consolidation）：回撤应为单向反向移动，而非横盘整理",
    "在回撤过程中过早入场，未等待受保护摆动形成或V形恢复完成就建立头寸",
    "未确认失败摆动形成就仓促入场，导致被诱导（Inducement）",
    "忽视回撤应进入FVG或PDA区域的规则，将任意价格区域的回调都视为交易机会",
    "混淆\"扩展遇扩展\"（看跌信号）与\"扩展遇回撤\"（看涨延续）的区别",
    "未等待日线完全收盘就判断回撤或反转，导致盘中波动造成误判",
    "忽视多时间框架一致性：低时间框架的回撤必须与高时间框架的偏差对齐",
    "在回撤中过早平仓，未能参与后续的趋势延续"
  ],
