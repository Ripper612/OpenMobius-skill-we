{
  "card_id": "reversal_closure",
  "type": "merged_concept",
  "canonical_term": "Candle 2 Closure",
  "aliases": [
    "c2c",
    "candle to closure",
    "Reversal Candle Closure",
    "reversal closure",
    "second candle closure",
    "第二根k线收盘"
  ],
  "school": "Price Action",
  "definition": "A candle closure where price sweeps the previous candle's high or low but closes back inside in the opposite direction, signaling that the next candle is expected to reverse and trade the other way.",
  "identification_rules": [
    "Mark the previous candle's high and low as reference levels.",
    "Confirm price wicks beyond (sweeps) that high or low intra-candle.",
    "Confirm the candle closes back inside the previous candle's range, opposite to the sweep direction.",
    "Distinguish from a continuation closure, where price takes out the level and closes beyond it in the trend direction.",
    "Pair the closure with a key level or point of interest before treating it as a valid reversal signal."
  ],
  "trading_implication": "A reversal closure forms the basis of a candle 2 closure within the fractal model, allowing the trader to anticipate candle 3 expansion in the new direction. After identifying the reversal closure at a key level, the trader looks for the next candle to continue the reversal, and uses the equilibrium of the expansion candle's range to anticipate where candle 4's wick should form before further extension.",
  "common_mistakes": [
    "Confusing a reversal closure with a continuation closure when price closes beyond rather than back inside the prior candle's range.",
    "Expecting a reversal at a key level without confirming an actual reversal closure (price hits the level but closes through it instead of back inside)."
  ],
