{
  "card_id": "reversal_entry",
  "type": "merged_concept",
  "canonical_term": "Reversal Entry",
  "aliases": [
    "protected swing entry",
    "Protected Swing Entry",
    "反转入场"
  ],
  "school": "ICT",
  "definition": "An entry taken immediately upon formation of a protected swing, confirmed by a closure through the opposing candle series (e.g., up-close candles for shorts, down-close candles for longs). The stop is placed on the protected high or low, and the trade is executed before any continuation structure forms.",
  "identification_rules": [
    "Price must sweep a relevant high or low and close back inside the range, forming a potential swing point.",
    "A closure through the series of opposing candles (up-close candles for shorts, down-close candles for longs) must occur to confirm the protected swing.",
    "The entry is taken on that confirming closure, with invalidation placed on the protected high/low (or alternatively on the candle bodies to tighten the stop).",
    "No continuation structure (higher low, opposing candle at a point of interest, or candle 4 retest) has yet formed at the time of entry.",
    "Price forms a V-shaped reversal or reversal within consolidation.",
    "The low is confirmed as a protected swing."
  ],
  "trading_implication": "Reversal entries allow participation at the earliest possible point of a new trend, but typically produce poor risk-to-reward because the stop must sit on the protected swing extreme far from the target. The analyst prefers waiting for a continuation entry (retest into a fair value gap or point of interest with a closure through opposing candles) which yields tighter stops and better R. If 2R cannot be achieved with stop on the protected swing, the trader may tighten the stop to the candle bodies or wait for a limit retest.",
  "common_mistakes": [
    "Taking a reversal entry when risk-to-reward to the target is below 2R instead of waiting for a continuation.",
    "Placing the stop on the protected swing extreme when a body-based invalidation would achieve required R (accepting the trade-off that wicks may sweep the body stop).",
    "Entering before the closure through the opposing candle series occurs, treating an unconfirmed swing as protected.",
    "Entering based on a single candle close without sufficient confirmation.",
    "Failing to distinguish reversal entries from continuation entries, missing better risk-reward setups.",
    "Blindly entering reversals without significant price levels (e.g., FVG, OB) supporting the reversal."
  ],
  "related_concepts": [],
  "merge_strategy": "llm_synthesis",
  "merge_model": "deepseek/deepseek-chat",
  "merge_notes": "Both cards are from ICT school; no conflict. The second card provides more precise identification rules and trading implications, which are adopted. The first card's rules about V-shaped reversal and protected swing confirmation are merged as they are complementary.",
