{
  "card_id": "risk_to_reward_management",
  "type": "merged_concept",
  "canonical_term": "Risk to Reward Management",
  "aliases": [
    "2R",
    "R:R",
    "R:R Ratio",
    "R:R比例",
    "risk to reward ratio",
    "Risk to Reward Ratio",
    "Risk-Reward Ratio",
    "Risk/Reward",
    "Risk/Reward Ratio",
    "rr management",
    "RR Management",
    "RRR",
    "solid rr",
    "Solid RR",
    "风险回报比"
  ],
  "school": "Risk Management",
  "definition": "The ratio of stop loss distance to target profit distance, expressed as 1:X or XR. Entry closer to stop yields higher RR but lower fill probability. Minimum 2R standard is typical. Improve RR by dropping to lower timeframes for precise entry, adjusting stop location, or using Mean Threshold.",
  "identification_rules": [
    "Determine entry price and stop loss price, calculate the point difference (risk distance).",
    "Determine target price and entry price, calculate the point difference (reward distance).",
    "Divide reward distance by risk distance to get ratio (e.g., 80 points reward / 40 points risk = 2:1, i.e., 2R).",
    "Ratio must be ≥2:1 (2R standard) to consider entry; if not, adjust entry or stop.",
    "Entry closer to stop gives higher RR but lower fill probability; trade-off required.",
    "Drop to lower timeframes (e.g., 15m→5m→1m) to find better entry, narrowing stop while keeping target to improve ratio.",
    "Adjust stop location (e.g., Breaker Block stop, Mean Threshold entry) to optimize ratio.",
    "Multi-timeframe alignment (HTF bias → MTF structure → LTF entry) yields higher RR.",
    "In A+ setups, partial profit targets can achieve multiple R multiples per trade.",
    "Define 1R as distance from entry to stop loss.",
    "Calculate R multiple: R = (target price - entry price) / (entry price - stop loss price).",
    "Express result as multiple, e.g., 2R, 2.6R, 3R, 5R.",
    "Assess R value before entry; if below minimum (usually 2R), reconsider entry or adjust stop."
  ],
  "trading_implication": "RR is core for evaluating trade quality. Choose among potential entries (FVG, OB, OTE, Breaker Block) balancing RR and fill probability. Multi-timeframe alignment and LTF precision can significantly improve RR (e.g., from 1:1.3 to 1:2.6 or 4:1). Higher RR allows profitability even with lower win rate. At 3R, move stop to breakeven to lock in risk-free trade.",
  "common_mistakes": [
    "Blindly pursuing highest RR while ignoring fill probability, leading to overly aggressive entries.",
    "Choosing entry based solely on RR without considering market structure and PD array quality.",
    "Failing to adjust RR expectations based on timeframe and market conditions.",
    "Accepting trades with RR below 2R, reducing expectancy.",
    "Using opposite end of order block as stop instead of swing low, increasing stop-out risk despite higher ratio.",
    "Not optimizing entry (e.g., Mean Threshold) to improve ratio, accepting initial low ratio.",
    "Entering on HTF without dropping to LTF, causing oversized stop and poor RR.",
    "Rushing entry without LTF confirmation (structure break, FVG), increasing risk of stop run.",
    "Using too wide stop leading to poor RR; failing to find precise entry on lower timeframe.",
    "Entering when RR < 2R, taking excessive risk.",
    "Expanding target too much to achieve 2R, ignoring realistic liquidity targets.",
    "Analyzing only one timeframe, leading to suboptimal entry and low RR.",
    "Setting stop too wide or target too close, resulting in poor actual RR.",
    "Not calculating RR before entry, trading without quantitative basis.",
    "After reaching 3R, not moving stop to breakeven, missing risk management opportunity.",
    "Setting stop too wide causing inflated RR but actual risk exceeds tolerance.",
    "Setting unrealistic target price; high RR trades may fail due to unattainable target.",
    "Over-pursuing high RR while ignoring entry quality, leading to frequent stops."
  ],
