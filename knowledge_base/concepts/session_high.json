{
  "card_id": "session_high",
  "type": "merged_concept",
  "canonical_term": "Session High",
  "aliases": [
    "AS.H",
    "as.h",
    "Asian Session High",
    "asian session high",
    "Intraday Session High",
    "intraday session high",
    "lo.h",
    "LO.H",
    "London Session High",
    "london session high",
    "new york session high",
    "New York Session High",
    "nyam.h",
    "NYAM.H",
    "Session High Level",
    "session high level"
  ],
  "school": "ICT",
  "definition": "特定交易时段（亚洲20:00-00:00、伦敦02:00-05:00、纽约AM 08:30-11:00 EST）内所有K线高点的最大值，标注为水平线作为该时段流动性上边界，用于判断价格吸引方向、反转框架及SMT背离信号的优先观察位置。",
  "identification_rules": [
    "在对应时段的K线序列中，取该时段内所有K线高点的最大值，即为该时段Session High",
    "时段结束后，将该最高价以水平线标注在图表上，保留至后续时段使用；标签格式参考：AS.H（亚洲）、LO.H（伦敦）、NYAM.H（纽约AM）",
    "可使用ICT Killzones & Pivots指标自动绘制各时段高点，需确认时段时间设置与亚洲/伦敦/纽约AM一致；水平线延伸截止时间可通过'drawing cut off time'参数调整",
    "观察后续时段价格是否对该高点形成有效位移（Directional Candle收盘突破）或仅扫过后回撤（Liquidity Sweep）",
    "在两个相关资产图表上同时标注对应时段的Session High水平线，对比是否同步突破，以识别SMT背离信号"
  ],
  "trading_implication": "Session High可作为：①Draw On Liquidity目标，偏向看涨时预期价格向上触及；②反转框架，价格扫过后未能有效位移收盘于其上方则预期转向下方目标；③SMT背离观察位，一个资产突破而相关资产未突破时形成反转辅助确认。在AMD框架下，亚洲Session High常作为伦敦操纵阶段的扫荡目标，伦敦Session High可作为纽约AM分配阶段的做空参考阻力位。需结合更高时间框架偏向及PD Array使用。",
  "common_mistakes": [
    "将价格扫过Session High（Liquidity Sweep）误判为有效突破，需观察是否有位移K线收盘确认",
    "忽略更高时间框架偏向，仅凭Session High被触及就判断反转，而未结合日线或月线结构确认",
    "仅凭Session High处出现SMT背离就立即入场做反转，而不等待结构确认或位移K线",
    "若相关资产随后也突破了Session High，则SMT信号已失效，不应继续持有反转预期"
  ],
