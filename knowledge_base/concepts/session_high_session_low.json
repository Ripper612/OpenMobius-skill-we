{
  "card_id": "session_high_session_low",
  "type": "merged_concept",
  "canonical_term": "Session High / Session Low",
  "aliases": [
    "asia session high",
    "Asia Session High",
    "asia session low",
    "Asia Session Low",
    "London Session High",
    "london session low",
    "London Session Low",
    "New York Session High",
    "New York Session Low",
    "new york session low"
  ],
  "school": "ICT",
  "definition": "特定交易时段（亚洲、伦敦、纽约）内形成的最高价与最低价，构成关键流动性水平，可用于框架叙事、设定价格目标或识别潜在反转点。",
  "identification_rules": [
    "在5分钟或更低时间框架上，标记亚洲时段（Asia Session）开盘至收盘期间的最高价和最低价水平线",
    "在伦敦时段（London Session）开盘至收盘期间，标记该时段形成的最高价和最低价水平线",
    "在纽约时段（New York Session）开盘后，参照前两个时段已标记的高低点水平线，观察价格是否触及或突破这些水平",
    "当某时段高点或低点尚未被价格触及时，将其视为有效的未扫除流动性水平，保持标注直至被价格触及"
  ],
  "trading_implication": "Session High / Session Low 作为流动性水平，可在三种场景下使用：1）作为 Draw On Liquidity 目标，价格在纽约时段向前一时段的高点或低点运动；2）作为反转框架，价格扫过某时段高低点后出现 Break of Structure 或位移，触发反向交易；3）与 Fair Value Gap 结合使用，在价格回测 FVG 后以未触及的 Session High / Session Low 作为止盈目标。当所有时段高低点均已被扫除时，可转而参考 Previous Day High / Previous Day Low 作为下一目标。",
  "common_mistakes": [
    "忽视已被触及的时段高低点仍继续将其作为有效目标，材料强调应区分已扫除与未扫除的水平",
    "在所有 Session High / Session Low 均已被取出后，未能切换至 Previous Day High / Previous Day Low 作为替代目标"
  ],
