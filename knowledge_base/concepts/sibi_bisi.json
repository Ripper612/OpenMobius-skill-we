{
  "card_id": "sibi_bisi",
  "type": "merged_concept",
  "canonical_term": "SIBI / BISI",
  "aliases": [
    "bearish fair value gap",
    "Bearish Fair Value Gap",
    "Bullish Fair Value Gap",
    "Buy Side Imbalance Sell Side Inefficiency",
    "Sell Side Imbalance Buy Side Inefficiency"
  ],
  "school": "ICT",
  "definition": "A three-candlestick pattern where the first candle's low does not overlap the third candle's high (SIBI, bearish) or the first candle's high does not overlap the third candle's low (BISI, bullish), creating an imbalance. SIBI indicates sell-side aggression; BISI indicates buy-side aggression. Price often returns to the gap.",
  "identification_rules": [
    "Identify a sequence of three consecutive candles.",
    "For SIBI (bearish), ensure the low of the first candle is above the high of the third candle, with no overlap.",
    "For BISI (bullish), ensure the high of the first candle is below the low of the third candle, with no overlap.",
    "The middle candle should be a large directional candle (the imbalance candle).",
    "The fair value gap is the price range between the first and third candle extremes."
  ],
  "trading_implication": "SIBI acts as resistance; BISI acts as support. Price retracing to the gap offers entry opportunities with stops beyond the gap. A close beyond the gap creates an inversion, signaling potential reversal or continuation. Old SIBI/BISI can be used as reaccumulation (support) or redistribution (resistance) zones when drawn to the opposite side of the market maker curve.",
  "common_mistakes": [
    "Treating a touch of consequent encroachment as a valid inversion without waiting for a full close beyond the gap.",
    "Entering on the initial return to the gap without confirmation of respect or inversion.",
    "Using a bullish BISI as support in a strongly bearish trend without higher-timeframe context.",
    "Misidentifying the gap by using candles that do not strictly meet the three-candle no-overlap condition."
  ],
