{
  "card_id": "smart_money_reversal",
  "type": "merged_concept",
  "canonical_term": "Smart Money Reversal",
  "aliases": [
    "Order Block at Smart Money Reversal",
    "order block at smart money reversal",
    "智能货币反转"
  ],
  "school": "ICT",
  "definition": "A reversal pattern where price reaches an important higher-time-frame level, sweeps buy-side or sell-side liquidity, then displaces and closes below the opening price of up-close candles (bearish) or above the opening price of down-close candles (bullish), validating a delivery direction shift.",
  "identification_rules": [
    "Price must reach an important higher-time-frame level (HTF PD array, order block, fair value gap, or significant swing).",
    "Price sweeps buy-side liquidity (above swing high) for bearish reversal, or sell-side liquidity (below swing low) for bullish reversal.",
    "After the sweep, a displacement candle must close below the opening price of the single or series of up-close candles (bearish) or above the opening price of the down-close candle series (bullish).",
    "The up-close or down-close candle series that gets closed through becomes the order block used as resistance or support on retrace.",
    "Without a sweep, the pattern can still qualify if a high-low-higher-high-lower-low sequence forms, but a preceding sweep is preferred.",
    "The reversal must form a short-term low (bullish) or high (bearish) to confirm validity.",
    "The pattern is only valid at important levels; identical price action at random spots is not a valid reversal."
  ],
  "trading_implication": "After validation, trade the retest of the order block opening price with stop beyond the swept high/low, targeting 2R minimum or opposing liquidity. For larger order block series, enter at the mean threshold (50% body) if opening price gives poor R:R. The reversal also seeds subsequent order blocks for continuation entries.",
  "common_mistakes": [
    "Identifying reversal at random spots without a higher-time-frame important level, leading to invalid order blocks and stop-outs.",
    "Confusing up-close candles that formed equal highs in a retracement with a true smart money reversal order block.",
    "Skipping the requirement that the displacement candle close below the opening price of the up-close candle series before entering.",
    "Placing stops on the opposite end of the order block for better R:R while accepting that price may wick the stop even when the trade is still valid.",
    "Entering at the reversal point itself instead of waiting for a retest of the order block."
  ],
