{
  "card_id": "stop_loss_placement",
  "type": "merged_concept",
  "canonical_term": "Stop Loss Placement",
  "aliases": [
    "Invalidation",
    "Invalidation Placement",
    "invalidation placement",
    "Stop Loss",
    "Stop Placement",
    "stop placement",
    "止损位置",
    "止损设置"
  ],
  "school": "Risk Management",
  "definition": "The method of determining stop-loss price levels based on market structure. Stops can be placed beyond breaker blocks (and overlapping FVGs), at swing highs/lows, or at the mean threshold (50% body) of opposing candles. The choice directly impacts risk-to-reward ratio and probability of being stopped out, requiring adjustment based on risk tolerance and target achievability.",
  "identification_rules": [
    "For short trades, use the high of the candle forming the FVG as stop, or a short-term swing high as alternative.",
    "For long trades, use the low of the candle forming the order block as stop, or a short-term swing low as alternative.",
    "Place stop just beyond the breaker block (below for longs, above for shorts) and overlapping FVG for optimal risk-to-reward.",
    "Place stop beyond the relevant swing high/low for a wider stop, accepting lower risk-to-reward.",
    "Consider other imbalances (FVG) or structural overlaps in the stop zone.",
    "Ensure the chosen stop distance allows a minimum 2R target; if not, tighten stop to the 50% body (mean threshold) of the opposing candle series.",
    "If neither full structural stop nor body-based stop yields 2R, wait for a continuation entry (new protected swing from FVG or sweep) rather than entering.",
    "For PD arrays like breaker, FVG, or inversion (not order blocks), define invalidation as a close back through that array.",
    "For projection-based targets, anchor stop just beyond the breaker to ensure favorable R multiples.",
    "Move stop to new protected swing or short-term high/low only after a clear market structure shift (MSS)."
  ],
  "trading_implication": "Stop placement dictates risk size and whether a trade meets the minimum 2R target. Breaker block stops offer better R:R but higher sweep risk; swing stops are safer but require larger moves. If no placement yields 2R, wait for continuation entries. After entry, trail stop to new protected swings only after MSS to lock profits.",
  "common_mistakes": [
    "Defaulting to swing high/low when a tighter breaker-block stop yields better R:R.",
    "Setting take-profit at 2R from a swing-based stop and getting stopped out because price nearly reached a closer target achievable with a breaker stop.",
    "Entering on a reversal when the protected-swing stop does not yield 2R, instead of waiting for a continuation entry.",
    "Treating a swing as protected without confirming a close through opposing candles or without an important level (FVG or liquidity sweep).",
    "Using body/mean-threshold stops on V-shape moves where a return into the body likely invalidates the setup.",
    "Applying order-block invalidation rules to other PD arrays (breaker, FVG, inversion) without redefining invalidation.",
    "Trusting a closure 'just over' an opposing candle rather than a full close over the candle body.",
    "Mechanically selecting stop without adjusting to market structure and R:R.",
    "Moving stop prematurely before MSS, leading to being stopped out by false breakouts.",
    "Ignoring short-term swing highs/lows as protective stops, setting stops too wide or too tight."
  ],
