{
  "card_id": "support_and_resistance",
  "type": "merged_concept",
  "canonical_term": "Support and Resistance",
  "aliases": [
    "S&R",
    "s&r"
  ],
  "school": "ICT",
  "definition": "Key time-based price levels (midnight open, 8:30, daily open, New York open) that act as floors preventing price from falling further or ceilings preventing price from rising. These levels also define premium versus discount zones relative to current price.",
  "identification_rules": [
    "Mark the midnight open (00:00 EST) and the 8:30 EST level as horizontal references on the chart.",
    "If price is above both midnight open and 8:30, treat the zone as a premium (resistance context for bearish setups).",
    "If price is below both midnight open and 8:30, treat the zone as a discount (support context for bullish setups).",
    "When price closes back through one of these levels, the level flips role and becomes support or resistance on the retest.",
    "Pair these time levels with an order block or fair value gap formed at midnight, 8:30, or 9:30 to confirm a reactive S/R zone."
  ],
  "trading_implication": "These levels are used daily to frame bias and locate reactions: midnight open and 8:30 act as support to push price higher or resistance to push it lower, and define premium/discount for entries. Combined with Judas swings and order block formations at 8:30 and 9:30, they help anticipate New York reversals or continuations, with price often retesting these levels before the distribution phase of the daily OHLC plays out.",
  "common_mistakes": [
    "Not explicitly stated"
  ],
