{
  "card_id": "swing_high_and_swing_low",
  "type": "merged_concept",
  "canonical_term": "Swing High and Swing Low",
  "aliases": [
    "Swing High",
    "Swing Low",
    "swing points",
    "turning points",
    "局部高低点",
    "摆动点",
    "摆动高点和摆动低点"
  ],
  "school": "ICT",
  "definition": "Local turning points in price action formed by adjacent candles. A swing high has a higher high than its left and right neighbors; a swing low has a lower low than its neighbors. They mark directional shifts, serve as liquidity pools, and anchor Fibonacci retracements for OTE entries.",
  "identification_rules": [
    "Swing high: a candle's high is higher than the highs of its immediate left and right candles; price subsequently declines.",
    "Swing low: a candle's low is lower than the lows of its immediate left and right candles; price subsequently rises.",
    "A swing point must be confirmed by at least one subsequent candle before marking; do not mark prematurely.",
    "Breakout validity is judged by candle close outside the swing point level; touching alone is not a valid break.",
    "Swing points can be identified on any timeframe; higher timeframe swing points are more reliable.",
    "When comparing correlated assets (e.g., ES vs NQ), mark swing points on the same date/price level on both charts and observe each asset's candle close relative to the level.",
    "Swing highs may have buy-side liquidity above; swing lows may have sell-side liquidity below."
  ],
  "trading_implication": "Swing points are key for market structure and Fibonacci anchoring. A failed break (price fails to close outside) often leads to a reversal back into the range (frame shift). A successful break suggests continuation. Use with Next Candle/Next Day Model for entry timing. Compare correlated assets at the same swing point to gauge relative strength. Combine with FVG, OB, etc. in a PD array for higher probability.",
  "common_mistakes": [
    "Treating every local high/low as a valid swing point without considering relativity and timeframe.",
    "Failing to distinguish swing points across timeframes, leading to incorrect stop/target placement.",
    "Confusing a touch of a swing point with a valid breakout; not using close outside as the criterion.",
    "Ignoring the reversal tendency after a failed break, missing Next Candle Model opportunities.",
    "Trading before confirmation (wait for at least one candle after swing point formation).",
    "Over-relying on low timeframe swing points, increasing noise; prioritize higher timeframes.",
    "Confusing swing points with order blocks; swing points are for liquidity and relative strength, not direct support/resistance.",
    "Neglecting to compare swing points across correlated assets for relative strength analysis."
  ],
