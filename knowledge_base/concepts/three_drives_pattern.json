{
  "card_id": "three_drives_pattern",
  "type": "merged_concept",
  "canonical_term": "Three Drives Pattern",
  "aliases": [],
  "school": "Price Action",
  "definition": "A price pattern of three successive swing points in the same direction (highs in an uptrend, lows in a downtrend), each slightly higher or lower, signaling exhaustion and potential reversal.",
  "identification_rules": [
    "Identify three consecutive swing highs where each high is marginally higher than the previous (uptrend) or three consecutive swing lows each marginally lower (downtrend).",
    "The third drive often forms a reversal candle with a long wick that closes back inside the prior range, indicating exhaustion."
  ],
  "trading_implication": "The pattern warns of trend exhaustion and a possible reversal. Traders may wait for confirmation such as a candle two closure or change in state of delivery before entering. Caution is needed if the pattern places entry near liquidity targets, as the move may overshoot.",
  "common_mistakes": [
    "Entering solely on the three drives pattern without waiting for confirmation (e.g., protected swing or change in state of delivery) can result in premature stop-outs."
  ],
