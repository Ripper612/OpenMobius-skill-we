{
  "card_id": "turtle_soup",
  "type": "merged_concept",
  "canonical_term": "Turtle Soup",
  "aliases": [
    "purge of a high",
    "purge of a low",
    "sweep",
    "sweep above highs",
    "sweep out previous highs"
  ],
  "school": "ICT",
  "definition": "价格触及或穿过前期摆动高点/低点，清除该区域流动性订单后反向运行的形态。确认条件为扫盘后K线收盘穿过形成该高/低点的K线序列，随后价格不继续朝原方向延伸，而是反向运动。可在多时间框架及特定时间窗口（如Silver Bullet框架）中应用。",
  "identification_rules": [
    "价格的影线（wick）触及或穿过前期有效摆动高点/低点（swing high/low）",
    "扫盘后K线收盘在该水平的反向一侧，或收盘穿过形成该高/低点的K线序列",
    "穿过后价格反向运行，不继续朝原突破方向延伸",
    "Sweep可分为浅层（价格仅触及）和深层（价格穿过并产生明显位移）两种形态",
    "扫盘后通常在反向运动中形成FVG、OB等结构点位",
    "需结合上位时间框架偏向确认，高时间框架的sweep可为低时间框架提供方向性支撑",
    "在Silver Bullet框架中，于10-11 a.m.时间窗口内观察价格是否触及或穿过前一小时K线的高点或低点"
  ],
  "trading_implication": "Sweep表明机构已清除止损/流动性订单，价格即将反向。确认后（收盘穿过K线序列或下一根K线延续）寻找反向入场机会，止损设于扫盘极值点。常与Change in State of Delivery、FVG、OB、Protected Swing等结构配合使用。Sweep强度及随后位移强度影响交易可信度与风险回报比。在Silver Bullet框架中，目标为前一小时K线的对侧。",
  "common_mistakes": [
    "在扫盘发生时立即入场，而非等待K线收盘确认或下一根K线的延续信号",
    "将单纯的价格触及或穿过高/低点误认为有效Sweep，未确认收盘位置的反向性",
    "忽视上位时间框架的偏向，仅在低时间框架识别Sweep，导致交易方向错误",
    "未结合FVG、OB等其他结构来确认Sweep后的具体入场点位",
    "将浅层Sweep与深层Sweep混淆，在缺乏充分位移的情况下入场",
    "在Silver Bullet框架中，于11 a.m.时间窗口结束后仍寻求入场，违反时间限制",
    "忽视Sweep后是否伴随充分的位移（Displacement），在盘整或回撤中入场"
  ],
