{
  "card_id": "up_close_candle",
  "type": "merged_concept",
  "canonical_term": "Opposing Candle",
  "aliases": [
    "Bullish Candle",
    "order block candle",
    "Up Close Candle",
    "up-close candle"
  ],
  "school": "General",
  "definition": "A candlestick where the close is above the open, indicating bullish sentiment. In ICT, a single up-close candle or a series occurring during a liquidity sweep of a swing high forms a bearish order block once price closes below them, acting as resistance on retest.",
  "identification_rules": [
    "The closing price is above the opening price.",
    "To qualify as a bearish order block, the up-close candle(s) must occur in the leg that sweeps a prior swing high or reaches into a higher-timeframe point of interest.",
    "Validation requires a subsequent candle to close below the body of the up-close candle(s), confirming displacement lower.",
    "When multiple consecutive up-close candles form the sweep leg, treat them as a series and mark the entire range as the order block.",
    "The opening price of the up-close candle is the key level expected to hold on retest; bodies should respect it even if wicks penetrate.",
    "The candle may have wicks, but the body indicates net upward movement."
  ],
  "trading_implication": "Up-close candles indicate bullish sentiment. In isolation, they suggest buying pressure and possible continuation. In ICT, when they occur as part of a liquidity sweep above a swing high, they become a bearish order block upon a close below, offering short entry resistance. The opening price of the candle(s) serves as the entry zone; projections from the manipulation leg can set targets.",
  "common_mistakes": [
    "Marking up-close candles as an order block without a corresponding liquidity sweep above a swing high or into a point of interest.",
    "Validating the order block before price actually closes below the up-close candle's body rather than just wicking through.",
    "Treating wick penetration into the order block as invalidation when the bodies still respect the opening price.",
    "Assuming all bullish candles are directional; a large wick relative to the body signals a potential reversal, not continuation.",
    "Ignoring prior candle context; a bullish candle after a downtrend could be a reversal or consolidation."
  ],
