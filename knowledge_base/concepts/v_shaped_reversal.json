{
  "card_id": "v_shaped_reversal",
  "type": "merged_concept",
  "canonical_term": "V-Shaped Reversal",
  "aliases": [
    "V-shape",
    "V-shape reversal",
    "V-shaped pattern",
    "V-shaped recovery",
    "V-shaped signature",
    "V底反转",
    "V形反转"
  ],
  "school": "ICT",
  "definition": "价格快速下跌至关键水平（如FVG、Order Block、摆动低点）后，在1-3根K线内立即以相反方向快速扩张反弹，形成扩张-扩张的V字形态。反转蜡烛通常具有小上影线，收盘穿过前期下跌K线序列，常伴随CSD与流动性扫荡确认。",
  "identification_rules": [
    "价格扩张下行至明确的关键水平（FVG、Order Block、摆动高/低点、前一日或前一周高/低点）",
    "在该关键水平处，价格未出现回撤或长期盘整，而是在1-3根K线内直接以相反方向快速扩张，形成扩张-扩张模式",
    "反转蜡烛收盘穿过前期下跌K线序列（down close candles），显示买方控制",
    "反转蜡烛通常具有小上影线，支持向上扩张；若上影线过大则质量下降",
    "下行部分应穿破前期支撑或形成流动性扫荡（sweep），上行部分应突破该支撑点位",
    "常与Change in State of Delivery（CSD）同时出现，确认反转有效性",
    "可结合SMT（相关资产分歧）或Protected Swing进一步验证",
    "可在高时间框架与低时间框架上识别（分形概念）；高时间框架表现为明显V形或长影线，低时间框架可见清晰的扩张-扩张结构",
    "反转后价格应在整理区间内形成新的受保护摆动点（Protected Swing），预期该低点在趋势延续中不被突破"
  ],
  "trading_implication": "V形反转是强势反转或延续信号。若发生在已有开放目标的延续阶段，作为延续PSP使用；若发生在趋势反转关键水平，则确认低点已形成。反转越快、收盘越干净，可信度越高。高时间框架偏差强时可在低时间框架V形反转处激进入场；偏差弱时应等待后续延续确认（回撤、盘整或新扩张）。止损设于Protected Swing低点，目标指向更高时间框架流动性。",
  "common_mistakes": [
    "在V形反转完全形成前过早入场，导致被流动性扫荡出局",
    "未确认CSD、SMT或关键水平就仓促入场，忽视形态完整性",
    "将缓慢反弹（超过3根K线）或长期盘整后的上升误认为V形反转；真正的V形应快速、尖锐",
    "混淆V形反转与延续结构，将扩张-回撤-扩张或扩张-盘整-扩张误当作反转",
    "在随机高低点交易V形反转，而非在相关的摆动高/低点（如前一日或前一周高/低）",
    "看到V形形态就立即入场，不等待后续延续信号（回撤、盘整或新扩张）确认",
    "在高时间框架上看到长影线就认为是反转，未在低时间框架验证是否真正形成扩张-扩张模式",
    "在延续阶段将V形反转误认为独立反转信号，导致逆向交易被止损",
    "忽视高时间框架目标已被触及的情况，在FOMO驱动下交易失败的延续",
    "在V形反转形成时同时扫出短期高点/低点，应等待额外确认再入场",
    "高时间框架偏差不足时激进交易低时间框架V形反转",
    "仅基于V形形态本身交易，忽视candle two收盘、SMT等确认信号",
    "未能观察价格是否尊重EQ；收盘穿过EQ后继续看涨会降低反转延续概率"
  ],
