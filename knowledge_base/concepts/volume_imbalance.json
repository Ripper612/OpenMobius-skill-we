{
  "card_id": "volume_imbalance",
  "type": "merged_concept",
  "canonical_term": "Volume Imbalance",
  "aliases": [
    "Volume and Balance",
    "volume and balance",
    "volume imbalance gap",
    "Volume Imbalance Gap"
  ],
  "school": "ICT",
  "definition": "A gap between the closing price of one candle and the opening price of the next where the bodies do not overlap but the wicks (high/low ranges) do, indicating trading occurred. Distinct from a Fair Value Gap (three candles, no overlap) and a true gap (no trading). Functions as a point of interest (PD Array) where price tends to react upon return.",
  "identification_rules": [
    "Locate two adjacent candles where the close of the first candle and the open of the next are at different prices, creating a visible gap between their bodies.",
    "Confirm that the high/low ranges (or wicks) of the two candles overlap, indicating that trading occurred within the gap area, distinguishing it from a Fair Value Gap.",
    "The Volume Imbalance zone is the price range between the close of the first candle and the open of the next candle.",
    "Exclude Gap: if the high/low ranges of the two candles do not overlap at all (no trading), it is a Gap, not a Volume Imbalance.",
    "Exclude Fair Value Gap: FVG consists of three candles with no overlap in the gap; Volume Imbalance involves only two candles with overlap.",
    "Optionally check if the gap lies within the OTE zone (0.62–0.79 Fibonacci retracement) for multiple resonance.",
    "In the Market Maker Model's buy-side curve (reaccumulation phase), can be marked as a PD Array within a Mitigation Block."
  ],
  "trading_implication": "Volume Imbalance acts as a PD Array where price is expected to react on return, often as support or resistance, but with weaker reaction than a Gap. It can be used within a Mitigation Block for precise entry, waiting for price to react and continue in the trend direction toward higher liquidity. Combining with OTE zone or other PD Arrays enhances reliability. Not a standalone entry; requires lower time frame confirmation.",
  "common_mistakes": [
    "Confusing Volume Imbalance with Fair Value Gap or true Gap, leading to incorrect trade expectations.",
    "Using Volume Imbalance as a standalone entry without lower time frame confirmation (e.g., order block formation) or broader structure context.",
    "Expecting the same level of price reaction as a Fair Value Gap, ignoring that Volume Imbalances may have less significance.",
    "Entering trades based solely on a Volume Imbalance without assessing its position within the broader market structure (e.g., premium vs. discount)."
  ],
