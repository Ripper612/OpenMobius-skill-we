{
  "card_id": "wick_size",
  "type": "merged_concept",
  "canonical_term": "Wick Size",
  "aliases": [
    "opposing run size",
    "wick length",
    "Wick Length",
    "影线大小",
    "影线长度",
    "灯芯大小"
  ],
  "school": "ICT",
  "definition": "The relative length of a candle's wick versus its body, indicating the strength of price rejection at key levels. A shallow wick (small relative to body) supports immediate expansion in the direction of the body; a large wick (large relative to body) suggests market hesitation or deep opposition, often requiring confirmation from the next candle before trading continuation.",
  "identification_rules": [
    "Compare wick length to the body of the candle after a reversal off a key level (e.g., previous day high/low).",
    "Classify as a shallow/small wick when the wick is a minor portion of the candle's range relative to the body.",
    "Classify as a large wick when the wick consumes most of the candle's range with a small body remaining.",
    "Contrast wick size with body size: shallow wick + large body = expansion type; large wick + small body = reversal type.",
    "Observe wick length at key price levels (e.g., previous day high, equilibrium) to gauge rejection strength.",
    "Wait for candle close to confirm wick size; avoid premature judgment during candle formation.",
    "Confirm wick formation using a lower time frame change in the state of delivery (hourly/30-min for Asia/London; 5-min/15-min for New York)."
  ],
  "trading_implication": "Wick size determines entry timing and expansion expectations. A shallow wick after a reversal at a key level supports trading the same daily candle's expansion in the new direction, allowing targets beyond the previous day high/low. A large wick means the current candle's range is mostly spent; wait for the following candle (candle three) to trade continuation, with targets adjusted back toward the daily open or equilibrium. Use lower time frame for entry after confirmation.",
  "common_mistakes": [
    "Ignoring wick size differences, expecting the same expansion for all reversal or continuation patterns.",
    "Trading continuation immediately on a large-wick candle without waiting for the next candle's confirmation.",
    "Trading reversal directly on a large-wick candle without considering lack of expansion support, leading to stop loss being hit.",
    "Failing to adjust targets based on wick size, setting overly aggressive targets for large-wick candles.",
    "Entering before candle close, misjudging wick size during formation.",
    "Expecting large-range expansion beyond previous day high/low when reversal candle has a large wick."
  ],
