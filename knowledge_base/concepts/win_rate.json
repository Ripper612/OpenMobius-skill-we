{
  "card_id": "win_rate",
  "type": "merged_concept",
  "canonical_term": "Win Rate",
  "aliases": [
    "Percentage of Profitable Trades",
    "percentage of profitable trades"
  ],
  "school": "Risk Management",
  "definition": "The percentage of trades that close profitable. Combined with a fixed risk-to-reward ratio and consistent position sizing, it determines whether a strategy is overall profitable per the win rate / R:R correlation table.",
  "identification_rules": [
    "Count the number of winning trades and divide by total trades taken to produce the win rate percentage.",
    "Pair the win rate with a fixed risk-to-reward ratio (e.g., 1:2) to read profitability from the win rate / R:R table.",
    "Validate that each trade in the sample uses consistent position sizing (fixed dollar or fixed percentage risk); otherwise the win rate figure does not map to profitability.",
    "Confirm the threshold: at 1:2 R:R, a win rate above ~34–40% produces profitability; at 1:1, 20% is unprofitable."
  ],
  "trading_implication": "Win rate alone does not determine profitability — it must be combined with a fixed R:R and consistent position sizing. A 1:2 fixed system at 50% win rate yields +1R over two trades only when each trade risks the same dollar amount. Inconsistent sizing breaks the correlation: a losing trade risking more than a winning trade wipes out the expected edge. Traders should select a target R:R, calculate the required win rate from the table, and enforce fixed-dollar or fixed-percentage risk per trade to realize the edge.",
  "common_mistakes": [
    "Assuming the win rate / R:R profitability table applies while using inconsistent position sizes across trades.",
    "Using fixed contract size instead of fixed dollar/percentage risk, which causes risk per trade to vary with stop distance and distorts realized R multiples.",
    "Risking more on some trades than others so that a 4R winner only recovers part of the prior losses, leaving the account down despite a 'winning' trade."
  ],
